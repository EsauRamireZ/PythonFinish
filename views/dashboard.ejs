<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --blue:#1f3a5f;
      --blue2:#2e5b88;
      --ink:#243b53;
      --muted:#5b6777;
      --bg:#f4f7fb;
      --card:#ffffff;
      --line:#d9e2ec;
      --soft:#f8fafc;
      --success:#15803d;
      --warning:#b45309;
      --danger:#b91c1c;
      --detail:#1d4ed8;
      --shadow:0 14px 28px rgba(31,58,95,.10);
    }
    body{font-family:Arial,Helvetica,sans-serif;background:var(--bg);color:var(--ink)}
    .app-shell{min-height:100vh}
    .topbar{background:#fff;border-bottom:4px solid var(--blue2);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;box-shadow:0 8px 20px rgba(31,58,95,.08)}
    .brand-left{display:flex;align-items:center;gap:12px}
    .logo-mini{width:52px;height:52px;border-radius:14px;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:800}
    .brand-copy small{display:block;color:var(--muted);font-weight:700}
    .brand-copy h2{color:var(--blue);font-size:24px}
    .topbar-right{display:flex;align-items:center;gap:12px;flex-wrap:wrap;color:var(--blue);font-weight:700}
    .logout-btn{border:none;text-decoration:none;background:var(--blue);color:#fff;border-radius:10px;padding:10px 16px;cursor:pointer;font-weight:700}

    .main-nav{display:flex;gap:2px;background:transparent;padding:12px 24px 0;position:relative;z-index:10;flex-wrap:wrap}
    .nav-item{position:relative}
    .nav-link{background:var(--blue);color:#fff;border:none;padding:15px 24px;font-size:16px;cursor:pointer;border-radius:10px 10px 0 0;font-weight:700}
    .nav-link.active,.nav-link:hover{background:var(--blue2)}
    .dropdown-menu{display:none;position:absolute;top:100%;left:0;min-width:240px;background:#fff;border:1px solid var(--line);border-radius:0 0 12px 12px;box-shadow:var(--shadow);overflow:hidden}
    .dropdown-link{width:100%;border:none;background:#fff;color:var(--blue);text-align:left;padding:14px 18px;cursor:pointer;font-size:15px;font-weight:600;border-bottom:1px solid #edf2f7}
    .dropdown-link:hover,.dropdown-link.active{background:#edf2f7;color:var(--blue)}
    .nav-item:hover .dropdown-menu{display:block}

    .main-content{padding:24px}
    .breadcrumb{margin-bottom:18px;color:var(--muted);font-size:15px;font-weight:600;background:#fff;padding:14px 18px;border-radius:16px;box-shadow:0 10px 24px rgba(31,58,95,.06)}
    .crumb-link{
      color:var(--blue);
      text-decoration:none;
      font-weight:800;
      cursor:pointer;
    }
    .crumb-link:hover{
      text-decoration:underline;
    }
    .module-card{background:#fff;border-radius:18px;padding:24px;box-shadow:0 10px 24px rgba(31,58,95,.06);border:1px solid #e2e8f0}
    .module-header{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:18px}
    .module-header h1{color:var(--blue);margin-bottom:6px;font-size:28px}
    .module-header p{color:var(--muted);line-height:1.6}
    .dashboard-welcome{display:grid;grid-template-columns:1.2fr .8fr;gap:20px}
    .hero-panel,.info-panel{background:linear-gradient(135deg,#f8fbff,#ffffff);border:1px solid #dbe7f3;border-radius:20px;padding:28px;box-shadow:0 12px 30px rgba(31,58,95,.06)}
    .hero-panel h1{font-size:34px;color:var(--blue);margin-bottom:8px}
    .hero-panel p,.info-panel p{color:var(--muted);line-height:1.7}
    .welcome-name{display:inline-flex;margin-top:18px;background:#eaf2fb;color:var(--blue);padding:12px 16px;border-radius:14px;font-weight:800}
    .info-panel h3{color:var(--blue);margin-bottom:10px}
    .info-list{display:flex;flex-direction:column;gap:10px;margin-top:14px}
    .info-item{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:12px 14px}

    .filter-box{margin-bottom:18px;background:var(--soft);border:1px solid #e2e8f0;border-radius:16px;padding:16px}
    .filter-grid{display:flex;align-items:end;gap:18px;flex-wrap:wrap}
    .field{display:flex;flex-direction:column;gap:8px;min-width:220px;flex:1}
    .field label{font-weight:700;color:var(--blue)}
    .field input,.field select{width:100%;height:46px;border:1px solid #cbd5e0;border-radius:10px;padding:0 14px;background:#fff;color:#2d3748;outline:none}
    .field textarea{width:100%;min-height:110px;border:1px solid #cbd5e0;border-radius:10px;padding:12px 14px;background:#fff;color:#2d3748;outline:none;resize:vertical}
    .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--blue2);box-shadow:0 0 0 3px rgba(46,91,136,.10)}
    .field input[type="checkbox"]{width:18px;height:18px}
    .field-full{grid-column:1/-1}
    .actions-inline,.crud-actions,.modal-actions,.table-actions{display:flex;gap:10px;flex-wrap:wrap}
    .table-tools{margin-bottom:10px;color:var(--blue);font-weight:700}
    .table-responsive{overflow:auto;border:1px solid #e2e8f0;border-radius:16px}
    .data-table{width:100%;border-collapse:collapse;background:#fff}
    .data-table thead th{background:var(--blue);color:#fff;padding:14px 12px;text-align:left;font-size:14px;white-space:nowrap}
    .data-table tbody td{padding:13px 12px;border-bottom:1px solid #edf2f7;color:#334155;vertical-align:middle}
    .data-table tbody tr:hover{background:#f8fbff}
    .pagination{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-top:18px}
    .pagination button{background:#fff;border:1px solid #cbd5e1;border-radius:10px;padding:9px 14px;cursor:pointer;font-weight:700;color:var(--blue)}
    .pagination button:disabled{opacity:.45;cursor:not-allowed}
    .pagination button.active{background:var(--blue);border-color:var(--blue);color:#fff}
    .btn{border:none;border-radius:10px;padding:10px 16px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:8px}
    .btn-success{background:var(--blue);color:#fff}.btn-secondary{background:#e2e8f0;color:#334155}.btn-primary{background:var(--detail);color:#fff}.btn-danger{background:var(--danger);color:#fff}.btn-warning{background:var(--warning);color:#fff}
    .badge{display:inline-block;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:700;background:#eef2ff;color:#3730a3}
    .empty{padding:24px;text-align:center;color:var(--muted)}
    .table-image{width:54px;height:54px;border-radius:50%;object-fit:cover;border:2px solid #dbeafe;background:#f8fafc}
    .form-screen{display:grid;gap:18px}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
    .check-card{display:flex;align-items:center;gap:10px;padding:14px;border:1px solid #dbe4ee;border-radius:12px;background:#f8fafc;min-height:46px}
    .detail-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
    .detail-box{padding:12px 14px;border:1px solid #e2e8f0;border-radius:12px;background:#fff;min-height:46px;display:flex;align-items:center;word-break:break-word}
    .detail-image{width:120px;height:120px;border-radius:18px;object-fit:cover;border:3px solid #dbeafe;background:#f8fafc}
    .perm-check{width:18px;height:18px;accent-color:var(--blue2);cursor:pointer}
    .perm-save{white-space:nowrap}

    .modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.55);display:none;align-items:center;justify-content:center;padding:20px;z-index:99}
    .modal-box{width:min(560px,100%);background:#fff;border-radius:20px;box-shadow:0 18px 45px rgba(15,23,42,.25);overflow:hidden}
    .modal-box.modal-sm{width:min(420px,100%)}
    .modal-header{padding:18px 22px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:center;gap:10px}
    .modal-header h2{color:var(--blue);font-size:20px}
    .modal-close{border:none;background:#e2e8f0;width:38px;height:38px;border-radius:10px;font-weight:800;cursor:pointer}
    .modal-body{padding:22px}
    .modal-body p{color:var(--muted);line-height:1.7}

    @media (max-width:900px){
      .main-nav{padding:12px 14px 0}
      .main-content{padding:14px}
      .field{min-width:100%}
      .topbar{padding:14px}
      .brand-copy h2{font-size:20px}
      .dashboard-welcome,.form-grid,.detail-grid{grid-template-columns:1fr}
      .data-table{min-width:760px}
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <header class="topbar">
      <div class="brand-left">
        <div class="logo-mini">Sys</div>
        <div class="brand-copy">
          <small>Proyecto Final</small>
          <h2>Mi Servidor</h2>
        </div>
      </div>
      <div class="topbar-right">
        <span><%= user.strNombreUsuario %> · <%= user.strNombrePerfil %></span>
        <a class="logout-btn" href="/logout">Cerrar sesión</a>
      </div>
    </header>

    <nav class="main-nav" id="mainNav"></nav>

    <main class="main-content">
      <div id="breadcrumbs" class="breadcrumb">Inicio</div>
      <div id="moduleContent"></div>
    </main>
  </div>

  <div class="modal-overlay" id="detailModalOverlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="detailModalTitle">Detalle</h2>
        <button class="modal-close" type="button" onclick="closeDetailModal()">✕</button>
      </div>
      <div class="modal-body" id="detailModalBody"></div>
    </div>
  </div>

  <div class="modal-overlay" id="confirmModalOverlay">
    <div class="modal-box modal-sm">
      <div class="modal-header">
        <h2 id="confirmModalTitle">Confirmación</h2>
        <button class="modal-close" type="button" onclick="closeConfirmModal()">✕</button>
      </div>
      <div class="modal-body">
        <p id="confirmModalMessage"></p>
        <div class="modal-actions" style="justify-content:flex-end;margin-top:20px">
          <button type="button" class="btn btn-secondary" onclick="closeConfirmModal()">Cancelar</button>
          <button type="button" class="btn btn-danger" id="confirmModalAccept">Aceptar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="statusModalOverlay">
    <div class="modal-box modal-sm">
      <div class="modal-header">
        <h2 id="statusModalTitle">Listo</h2>
        <button class="modal-close" type="button" onclick="closeStatusModal()">✕</button>
      </div>
      <div class="modal-body">
        <p id="statusModalMessage"></p>
      </div>
    </div>
  </div>

<script>
const APP={
  menus:<%- JSON.stringify(menus) %>,
  permissions:<%- JSON.stringify(permissions) %>,
  user:<%- JSON.stringify(user) %>,
  catalogs:null,
  state:{
    view:'home',
    moduleKey:null,
    moduleName:'',
    menuName:'',
    page:1,
    search:'',
    editingId:null,
    permissionFilterPerfil:'',
    permissionFilterModulo:'',
    permissionRows:[]
  },
  confirmAction:null,
  statusTimer:null
};

const schemas={
  perfil:{
    title:'Perfiles',
    singleTitle:'Perfil',
    description:'Administración de perfiles del sistema.',
    endpoint:'/api/perfiles',
    search:true,
    searchLabel:'Perfil',
    searchPlaceholder:'Buscar perfil',
    columns:[
      {key:'strNombrePerfil',label:'Perfil'},
      {key:'bitAdministrador',label:'Administrador',render:v=>v?'<span class="badge">Sí</span>':'No'}
    ],
    detailLabels:{strNombrePerfil:'Perfil',bitAdministrador:'Administrador'},
    form:[
      {name:'strNombrePerfil',label:'Perfil',type:'text',maxLength:80,required:true},
      {name:'bitAdministrador',label:'Administrador',type:'checkbox'}
    ]
  },
  modulo:{
    title:'Módulos',
    singleTitle:'Módulo',
    description:'Administración de módulos del sistema.',
    endpoint:'/api/modulos',
    search:true,
    searchLabel:'Módulo',
    searchPlaceholder:'Buscar módulo',
    columns:[
      {key:'strNombreModulo',label:'Módulo'},
      {key:'strClaveModulo',label:'Clave'}
    ],
    detailLabels:{strNombreModulo:'Módulo',strClaveModulo:'Clave',strRuta:'Ruta'},
    form:[
      {name:'strNombreModulo',label:'Módulo',type:'text',maxLength:80,required:true},
      {name:'strClaveModulo',label:'Clave',type:'text',maxLength:50,required:true},
      {name:'strRuta',label:'Ruta',type:'text',maxLength:120,required:true}
    ]
  },
  permisos_perfil:{
    title:'Permisos por perfil',
    singleTitle:'Permiso',
    description:'Asignación de permisos por perfil con guardado por fila.',
    endpoint:'/api/permisos-perfil',
    search:false,
    columns:[
      {key:'strNombrePerfil',label:'Perfil'},
      {key:'strNombreModulo',label:'Módulo'}
    ],
    detailLabels:{strNombrePerfil:'Perfil',strNombreModulo:'Módulo',bitAgregar:'Agregar',bitEditar:'Editar',bitConsulta:'Consultar',bitEliminar:'Eliminar',bitDetalle:'Detalle'},
    form:[
      {name:'idPerfil',label:'Perfil',type:'select',optionsKey:'perfiles',required:true,textKey:'strNombrePerfil'},
      {name:'idModulo',label:'Módulo',type:'select',optionsKey:'modulos',required:true,textKey:'strNombreModulo'}
    ]
  },
  usuario:{
    title:'Usuarios',
    singleTitle:'Usuario',
    description:'Administración de usuarios del sistema.',
    endpoint:'/api/usuarios',
    search:true,
    searchLabel:'Usuario',
    searchPlaceholder:'Buscar usuario o correo',
    columns:[
      {key:'strImagen',label:'Foto',render:v=>v?`<img class="table-image" src="${escapeAttr(v)}" alt="Foto">`:'<span class="badge">Sin foto</span>'},
      {key:'strNombreUsuario',label:'Usuario'},
      {key:'strNombrePerfil',label:'Perfil'},
      {key:'strCorreo',label:'Correo'},
      {key:'strNumeroCelular',label:'Teléfono'},
      {key:'strNombreEstado',label:'Estado'}
    ],
    detailLabels:{strNombreUsuario:'Usuario',idPerfil:'Perfil',strPwd:'Contraseña',idEstadoUsuario:'Estado',strCorreo:'Correo',strNumeroCelular:'Teléfono',strImagen:'Foto'},
    form:[
      {name:'strNombreUsuario',label:'Usuario',type:'text',maxLength:80,required:true},
      {name:'idPerfil',label:'Perfil',type:'select',optionsKey:'perfiles',required:true,textKey:'strNombrePerfil'},
      {name:'strPwd',label:'Contraseña',type:'password',maxLength:120,required:true},
      {name:'idEstadoUsuario',label:'Estado',type:'select',optionsKey:'estados',required:true,textKey:'strNombreEstado'},
      {name:'strCorreo',label:'Correo',type:'email',maxLength:120,required:true},
      {name:'strNumeroCelular',label:'Teléfono',type:'text',maxLength:20,required:true},
      {name:'strImagen',label:'Foto',type:'file',accept:'image/png,image/jpeg,image/jpg,image/webp'}
    ]
  }
};

function escapeHtml(value){return String(value ?? '').replace(/[&<>\"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));}
function escapeAttr(value){return escapeHtml(value);}
function boolToText(value){return value ? 'Sí' : 'No';}
function getPermission(){return APP.permissions[APP.state.moduleKey] || {};}

function renderPagination(totalPages,currentPage,callbackName){
  totalPages=Number(totalPages)||1;
  currentPage=Number(currentPage)||1;
  if(totalPages<=1) return '';
  let html='';
  html+=`<button ${currentPage===1?'disabled':''} onclick="${callbackName}(${currentPage-1})">&lt;</button>`;
  for(let i=1;i<=totalPages;i++){
    html+=`<button class="${i===currentPage?'active':''}" onclick="${callbackName}(${i})">${i}</button>`;
  }
  html+=`<button ${currentPage===totalPages?'disabled':''} onclick="${callbackName}(${currentPage+1})">&gt;</button>`;
  return html;
}

async function loadAllPermissionRows(){
  let page=1;
  let totalPages=1;
  let allRows=[];
  do{
    const res=await fetch(`/api/permisos-perfil?page=${page}`);
    const json=await res.json();
    const rows=json.data||[];
    totalPages=json.totalPages||1;
    allRows=allRows.concat(rows);
    page++;
  }while(page<=totalPages);
  APP.state.permissionRows=allRows;
}

function applyPermissionFilters(){
  const perfilInput=document.getElementById('permissionFilterPerfil');
  const moduloInput=document.getElementById('permissionFilterModulo');
  APP.state.permissionFilterPerfil=perfilInput ? perfilInput.value.trim().toLowerCase() : '';
  APP.state.permissionFilterModulo=moduloInput ? moduloInput.value.trim().toLowerCase() : '';
  APP.state.page=1;
  renderPermissionsTable(schemas.permisos_perfil, APP.state.permissionRows || [], 1);
}

function clearPermissionFilters(){
  APP.state.permissionFilterPerfil='';
  APP.state.permissionFilterModulo='';
  APP.state.page=1;
  const perfilInput=document.getElementById('permissionFilterPerfil');
  const moduloInput=document.getElementById('permissionFilterModulo');
  if(perfilInput) perfilInput.value='';
  if(moduloInput) moduloInput.value='';
  renderPermissionsTable(schemas.permisos_perfil, APP.state.permissionRows || [], 1);
}

function loadPermissionPage(page){
  APP.state.page=page;
  renderPermissionsTable(schemas.permisos_perfil, APP.state.permissionRows || [], 1);
}

function setBreadcrumb(){
  const crumbs=[`<a href="javascript:void(0)" onclick="renderHome()" class="crumb-link">Inicio</a>`];

  if(APP.state.menuName){
    crumbs.push(`<span>${escapeHtml(APP.state.menuName)}</span>`);
  }

  if(APP.state.moduleName){
    crumbs.push(`<span>${escapeHtml(APP.state.moduleName)}</span>`);
  }

  if(APP.state.view==='create'){
    crumbs.push('<span>Agregar</span>');
  }

  if(APP.state.view==='edit'){
    crumbs.push('<span>Editar</span>');
  }

  document.getElementById('breadcrumbs').innerHTML=crumbs.join(' &rsaquo; ');
}

function buildMenus(){
  const nav=document.getElementById('mainNav');
  nav.innerHTML='';
  APP.menus.forEach(menu=>{
    const visible=(menu.modulos||[]).filter(mod=>{
      const p=APP.permissions[mod.clave]||{};
      return p.agregar||p.editar||p.consulta||p.eliminar||p.detalle;
    });
    if(!visible.length) return;
    const item=document.createElement('div'); item.className='nav-item';
    const button=document.createElement('button'); button.className='nav-link'; button.textContent=menu.nombre; button.onclick=()=>{};
    const dropdown=document.createElement('div'); dropdown.className='dropdown-menu';
    visible.forEach(mod=>{
      const sub=document.createElement('button');
      sub.className='dropdown-link';
      sub.textContent=mod.nombre;
      sub.onclick=()=>openModule(menu.nombre,mod);
      dropdown.appendChild(sub);
    });
    item.appendChild(button);
    item.appendChild(dropdown);
    nav.appendChild(item);
  });
}

async function boot(){
  const res=await fetch('/api/catalogos/base');
  APP.catalogs=await res.json();
  buildMenus();
  renderHome();
}

function highlightNav(){
  document.querySelectorAll('.dropdown-link').forEach(el=>el.classList.toggle('active',el.textContent===APP.state.moduleName && APP.state.view!=='home'));
  document.querySelectorAll('.nav-link').forEach(el=>el.classList.toggle('active',el.textContent===APP.state.menuName && APP.state.view!=='home'));
}

function renderHome(){
  APP.state.view='home';
  APP.state.menuName='';
  APP.state.moduleName='';
  APP.state.moduleKey=null;
  APP.state.page=1;
  APP.state.search='';
  APP.state.editingId=null;
  highlightNav();
  setBreadcrumb();
  document.getElementById('moduleContent').innerHTML=`
    <div class="dashboard-welcome">
      <section class="hero-panel">
        <h1>Bienvenido</h1>
        <p>Accediste correctamente al sistema. Desde el menú superior puedes entrar a cada módulo disponible según tu perfil.</p>
        <div class="welcome-name">${escapeHtml(APP.user.strNombreUsuario)}</div>
      </section>
      <aside class="info-panel">
        <h3>Datos de acceso</h3>
        <p>Estos son los datos de tu cuenta en el sistema.</p>
        <div class="info-list">
          <div class="info-item"><strong>Perfil:</strong> ${escapeHtml(APP.user.strNombrePerfil || '')}</div>
          <div class="info-item"><strong>Correo:</strong> ${escapeHtml(APP.user.strCorreo || '')}</div>
          <div class="info-item"><strong>Teléfono:</strong> ${escapeHtml(APP.user.strNumeroCelular || '')}</div>
        </div>
      </aside>
    </div>`;
}

function openModule(menuName,mod){
  APP.state.menuName=menuName;
  APP.state.moduleName=mod.nombre;
  APP.state.moduleKey=mod.clave;
  APP.state.page=1;
  APP.state.search='';
  APP.state.editingId=null;
  APP.state.view='list';
  highlightNav();
  setBreadcrumb();
  if(schemas[mod.clave]?.endpoint) loadList(); else loadStatic(mod.nombre);
}

async function loadList(page=1){
  APP.state.view='list';
  APP.state.page=page;
  APP.state.editingId=null;
  setBreadcrumb();
  const schema=schemas[APP.state.moduleKey];

  if(APP.state.moduleKey==='permisos_perfil'){
    await loadAllPermissionRows();
    renderPermissionsTable(schema, APP.state.permissionRows || [], 1);
    return;
  }

  const q=schema.search?`?page=${page}&search=${encodeURIComponent(APP.state.search||'')}`:`?page=${page}`;
  const res=await fetch(schema.endpoint+q);
  const json=await res.json();
  renderList(schema,json.data||[],json.totalPages||1);
}

function renderList(schema,rows,totalPages){
  const p=getPermission();
  if(APP.state.moduleKey==='permisos_perfil') return renderPermissionsTable(schema,rows,totalPages);
  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div>
          <h1>${schema.title}</h1>
          <p>${schema.description}</p>
        </div>
        <div class="table-actions">
          ${p.agregar?`<button class="btn btn-success" onclick="openCreateForm()">+ Agregar</button>`:''}
        </div>
      </div>
      <div class="filter-box">
        <div class="filter-grid">
          ${schema.search?`<div class="field"><label>${schema.searchLabel}</label><input id="searchBox" type="text" placeholder="${schema.searchPlaceholder}" value="${escapeHtml(APP.state.search)}"></div>`:''}
          <div class="actions-inline">
            ${schema.search?`<button class="btn btn-success" onclick="applySearch()">Buscar</button>`:''}
            ${schema.search?`<button class="btn btn-secondary" onclick="clearSearch()">Limpiar</button>`:''}
          </div>
        </div>
      </div>
      <div class="table-tools">Registros encontrados</div>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              ${schema.columns.map(c=>`<th>${c.label}</th>`).join('')}
              <th>Detalle</th>
              <th>Editar</th>
              <th>Eliminar</th>
            </tr>
          </thead>
          <tbody>
            ${rows.length ? rows.map(row=>`
              <tr>
                ${schema.columns.map(c=>`<td>${c.render?c.render(row[c.key],row):escapeHtml(row[c.key]??'')}</td>`).join('')}
                <td>${p.detalle?`<button class="btn btn-primary" onclick="viewRecord(${row.id})">Ver</button>`:''}</td>
                <td>${p.editar?`<button class="btn btn-warning" onclick="openEditForm(${row.id})">Editar</button>`:''}</td>
                <td>${p.eliminar?`<button class="btn btn-danger" onclick="confirmDelete(${row.id})">Eliminar</button>`:''}</td>
              </tr>`).join('') : `<tr><td colspan="${schema.columns.length+3}"><div class="empty">No hay registros para mostrar.</div></td></tr>`}
          </tbody>
        </table>
      </div>
      <div class="pagination">${renderPagination(totalPages,APP.state.page,'loadList')}</div>
    </div>`;
}

function renderPermissionsTable(schema,rows,totalPages){
  const p=getPermission();

  const perfilFilter=(APP.state.permissionFilterPerfil || '').toLowerCase();
  const moduloFilter=(APP.state.permissionFilterModulo || '').toLowerCase();

  const filteredRows=(rows||[]).filter(row=>{
    const perfilOk=!perfilFilter || String(row.strNombrePerfil || '').toLowerCase().includes(perfilFilter);
    const moduloOk=!moduloFilter || String(row.strNombreModulo || '').toLowerCase().includes(moduloFilter);
    return perfilOk && moduloOk;
  });

  const pageSize=5;
  const localTotalPages=Math.max(1, Math.ceil(filteredRows.length / pageSize));
  if(APP.state.page>localTotalPages) APP.state.page=localTotalPages;

  const start=(APP.state.page-1)*pageSize;
  const paginatedRows=filteredRows.slice(start, start + pageSize);

  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div>
          <h1>${schema.title}</h1>
          <p>${schema.description}</p>
        </div>
        <div class="table-actions">
          ${p.agregar?`<button class="btn btn-success" onclick="openCreateForm()">+ Agregar</button>`:''}
        </div>
      </div>

      <div class="filter-box">
        <div class="filter-grid">
          <div class="field">
            <label>Perfil</label>
            <input id="permissionFilterPerfil" type="text" placeholder="Filtrar por perfil" value="${escapeHtml(APP.state.permissionFilterPerfil || '')}">
          </div>
          <div class="field">
            <label>Módulo</label>
            <input id="permissionFilterModulo" type="text" placeholder="Filtrar por módulo" value="${escapeHtml(APP.state.permissionFilterModulo || '')}">
          </div>
          <div class="actions-inline">
            <button class="btn btn-success" onclick="applyPermissionFilters()">Buscar</button>
            <button class="btn btn-secondary" onclick="clearPermissionFilters()">Limpiar</button>
          </div>
        </div>
      </div>

      <div class="table-tools">Permisos configurados</div>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>Perfil</th>
              <th>Módulo</th>
              <th>Agregar</th>
              <th>Editar</th>
              <th>Consultar</th>
              <th>Eliminar</th>
              <th>Detalle</th>
              <th>Guardar</th>
              <th>Detalle</th>
              <th>Eliminar</th>
            </tr>
          </thead>
          <tbody>
            ${paginatedRows.length ? paginatedRows.map(row=>`
              <tr>
                <td>${escapeHtml(row.strNombrePerfil)}</td>
                <td>${escapeHtml(row.strNombreModulo)}</td>
                <td><input class="perm-check" type="checkbox" data-field="bitAgregar" ${row.bitAgregar?'checked':''}></td>
                <td><input class="perm-check" type="checkbox" data-field="bitEditar" ${row.bitEditar?'checked':''}></td>
                <td><input class="perm-check" type="checkbox" data-field="bitConsulta" ${row.bitConsulta?'checked':''}></td>
                <td><input class="perm-check" type="checkbox" data-field="bitEliminar" ${row.bitEliminar?'checked':''}></td>
                <td><input class="perm-check" type="checkbox" data-field="bitDetalle" ${row.bitDetalle?'checked':''}></td>
                <td>${p.editar?`<button class="btn btn-success perm-save" onclick="savePermissionRow(this, ${row.id}, ${row.idPerfil}, ${row.idModulo})">Guardar</button>`:''}</td>
                <td>${p.detalle?`<button class="btn btn-primary" onclick="viewRecord(${row.id})">Ver</button>`:''}</td>
                <td>${p.eliminar?`<button class="btn btn-danger" onclick="confirmDelete(${row.id})">Eliminar</button>`:''}</td>
              </tr>`).join('') : `<tr><td colspan="10"><div class="empty">No hay registros para mostrar.</div></td></tr>`}
          </tbody>
        </table>
      </div>

      <div class="pagination">${renderPagination(localTotalPages,APP.state.page,'loadPermissionPage')}</div>
    </div>`;
}

function applySearch(){
  const input=document.getElementById('searchBox');
  APP.state.search=input?input.value.trim():'';
  loadList(1);
}

function clearSearch(){
  APP.state.search='';
  const input=document.getElementById('searchBox');
  if(input) input.value='';
  loadList(1);
}

async function openCreateForm(){
  APP.state.view='create';
  APP.state.editingId=null;

  if(APP.state.moduleKey==='usuario' || APP.state.moduleKey==='permisos_perfil'){
    const catRes=await fetch('/api/catalogos/base');
    APP.catalogs=await catRes.json();
  }

  setBreadcrumb();
  renderForm();
}

async function openEditForm(id){
  APP.state.view='edit';
  APP.state.editingId=id;

  if(APP.state.moduleKey==='usuario' || APP.state.moduleKey==='permisos_perfil'){
    const catRes=await fetch('/api/catalogos/base');
    APP.catalogs=await catRes.json();
  }

  setBreadcrumb();
  renderForm(await getRecord(id));
}

async function getRecord(id){
  const schema=schemas[APP.state.moduleKey];
  const res=await fetch(`${schema.endpoint}/${id}`);
  const json=await res.json();
  return json.data||{};
}

function renderForm(data={}){
  const schema=schemas[APP.state.moduleKey];
  const title=APP.state.view==='edit' ? `Editar ${schema.singleTitle}` : `Agregar ${schema.singleTitle}`;
  const p=getPermission();
  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card form-screen">
      <div class="module-header">
        <div>
          <h1>${title}</h1>
          <p>Formulario independiente dentro de la misma pantalla.</p>
        </div>
      </div>
      <form id="entityForm">
        <input type="hidden" name="id" value="${data.id || ''}">
        <div class="form-grid">
          ${schema.form.map(field=>renderField(field,data,schema)).join('')}
        </div>
        <div class="modal-actions" style="justify-content:flex-end;margin-top:22px">
          <button type="button" class="btn btn-secondary" onclick="loadList(${APP.state.page || 1})">Cancelar</button>
          ${(APP.state.view==='create' && p.agregar) || (APP.state.view==='edit' && p.editar) ? '<button type="submit" class="btn btn-success">Guardar</button>' : ''}
        </div>
      </form>
    </div>`;
  document.getElementById('entityForm').onsubmit=saveRecord;
}

function renderField(field,data,schema){
  if(field.type==='checkbox'){
    return `<label class="check-card ${schema.title==='Permisos por perfil'?'':'field-full'}"><input type="checkbox" name="${field.name}" ${data[field.name]?'checked':''}> <span>${field.label}</span></label>`;
  }
  if(field.type==='select'){
    const options=(APP.catalogs[field.optionsKey]||[]).map(opt=>`<option value="${opt.id}" ${String(opt.id)===String(data[field.name]||'')?'selected':''}>${escapeHtml(opt[field.textKey]||'')}</option>`).join('');
    return `<div class="field"><label>${field.label}</label><select name="${field.name}" ${field.required?'required':''}><option value="">Seleccione...</option>${options}</select></div>`;
  }
  if(field.type==='file'){
    return `<div class="field field-full"><label>${field.label}</label><input type="file" name="${field.name}" accept="${field.accept||''}">${data.strImagen?`<div style="margin-top:12px"><img src="${escapeAttr(data.strImagen)}" alt="Foto" class="detail-image"></div>`:''}</div>`;
  }
  return `<div class="field"><label>${field.label}</label><input type="${field.type}" name="${field.name}" maxlength="${field.maxLength||''}" value="${escapeAttr(data[field.name]??'')}" ${field.required?'required':''}></div>`;
}

async function saveRecord(e){
  e.preventDefault();
  const schema=schemas[APP.state.moduleKey];
  const id=e.target.querySelector('[name="id"]').value;
  const hasFile=schema.form.some(f=>f.type==='file');
  const method=id?'PUT':'POST';
  let options={method};

  if(hasFile){
    const fd=new FormData(e.target);
    fd.delete('id');
    schema.form.forEach(field=>{
      if(field.type==='checkbox') fd.set(field.name, fd.get(field.name)?'true':'false');
    });
    options.body=fd;
  }else{
    const payload={};
    schema.form.forEach(field=>{
      const el=e.target.querySelector(`[name="${field.name}"]`);
      if(!el) return;
      payload[field.name]=field.type==='checkbox' ? el.checked : el.value;
    });

    if(APP.state.moduleKey==='permisos_perfil'){
      payload.bitAgregar=false;
      payload.bitEditar=false;
      payload.bitConsulta=false;
      payload.bitEliminar=false;
      payload.bitDetalle=false;
    }
    options.headers={'Content-Type':'application/json'};
    options.body=JSON.stringify(payload);
  }

  const res=await fetch(id?`${schema.endpoint}/${id}`:schema.endpoint,options);
  const json=await res.json();

  if(!res.ok || !json.ok){
    alert(json.message || 'No se pudo guardar');
    return;
  }

  if(APP.state.moduleKey==='perfil'){
    const catRes=await fetch('/api/catalogos/base');
    APP.catalogs=await catRes.json();
  }

  showStatusModal('Acción realizada', id ? 'El registro se guardó correctamente.' : 'El registro se agregó correctamente.');
  loadList(id ? APP.state.page : 1);
}

async function savePermissionRow(button, rowId, idPerfil, idModulo){
  const tr=button.closest('tr');
  const payload={
    idPerfil,
    idModulo,
    bitAgregar: tr.querySelector('[data-field="bitAgregar"]').checked,
    bitEditar: tr.querySelector('[data-field="bitEditar"]').checked,
    bitConsulta: tr.querySelector('[data-field="bitConsulta"]').checked,
    bitEliminar: tr.querySelector('[data-field="bitEliminar"]').checked,
    bitDetalle: tr.querySelector('[data-field="bitDetalle"]').checked
  };
  const res=await fetch(`/api/permisos-perfil/${rowId}`,{
    method:'PUT',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(payload)
  });
  const json=await res.json();
  if(!res.ok || !json.ok){
    alert(json.message || 'No se pudo guardar');
    return;
  }
  showStatusModal('Acción realizada','Los permisos se guardaron correctamente.');
}

function normalizeDetailValue(key,value){
  if(key==='bitAdministrador' || key.startsWith('bit')) return boolToText(!!value);
  if(key==='strImagen') return value ? `<img src="${escapeAttr(value)}" alt="Imagen" class="detail-image">` : 'Sin foto';
  if(key==='idPerfil'){
    const item=(APP.catalogs.perfiles||[]).find(x=>String(x.id)===String(value));
    return escapeHtml(item?.strNombrePerfil || value || '');
  }
  if(key==='idEstadoUsuario'){
    const item=(APP.catalogs.estados||[]).find(x=>String(x.id)===String(value));
    return escapeHtml(item?.strNombreEstado || value || '');
  }
  return escapeHtml(value ?? '');
}

async function viewRecord(id){
  const schema=schemas[APP.state.moduleKey];
  const data=await getRecord(id);
  const keys=Object.keys(data).filter(k=>k!=='id');
  const html=`<div class="detail-grid">${keys.map(key=>`<div class="field ${key==='strImagen'?'field-full':''}"><label>${escapeHtml(schema.detailLabels?.[key] || key)}</label><div class="detail-box">${normalizeDetailValue(key,data[key])}</div></div>`).join('')}</div><div class="modal-actions" style="justify-content:flex-end;margin-top:20px"><button type="button" class="btn btn-primary" onclick="closeDetailModal()">Cerrar</button></div>`;
  openDetailModal(`Detalle de ${schema.singleTitle}`,html);
}

function confirmDelete(id){
  openConfirmModal('Confirmar eliminación','¿Estás seguro de eliminar este registro?',async ()=>{
    const schema=schemas[APP.state.moduleKey];
    const res=await fetch(`${schema.endpoint}/${id}`,{method:'DELETE'});
    const json=await res.json();
    if(!res.ok || !json.ok){
      alert(json.message || 'No se pudo eliminar');
      return;
    }
    closeConfirmModal();
    showStatusModal('Acción realizada','El registro se eliminó correctamente.');
    loadList(APP.state.page);
  });
}

async function loadStatic(moduleName){
  const res=await fetch(`/api/static/${APP.state.moduleKey}`);
  const json=await res.json();
  const a=json.actions||{};
  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div>
          <h1>${moduleName}</h1>
          <p>Módulo estático del sistema.</p>
        </div>
      </div>
      <div class="crud-actions">
        ${a.agregar?'<button class="btn btn-success">Agregar</button>':''}
        ${a.editar?'<button class="btn btn-warning">Editar</button>':''}
        ${a.eliminar?'<button class="btn btn-danger">Eliminar</button>':''}
        ${a.consulta?'<button class="btn btn-secondary">Consultar</button>':''}
        ${a.detalle?'<button class="btn btn-primary">Detalle</button>':''}
      </div>
      <div class="filter-box" style="margin-top:18px">
        <p>Esta pantalla solo muestra los botones permitidos por el perfil.</p>
      </div>
    </div>`;
}

function openDetailModal(title,html){
  document.getElementById('detailModalTitle').textContent=title;
  document.getElementById('detailModalBody').innerHTML=html;
  document.getElementById('detailModalOverlay').style.display='flex';
}

function closeDetailModal(){
  document.getElementById('detailModalOverlay').style.display='none';
  document.getElementById('detailModalBody').innerHTML='';
}

function openConfirmModal(title,message,onAccept){
  document.getElementById('confirmModalTitle').textContent=title;
  document.getElementById('confirmModalMessage').textContent=message;
  APP.confirmAction=onAccept;
  document.getElementById('confirmModalOverlay').style.display='flex';
}

function closeConfirmModal(){
  document.getElementById('confirmModalOverlay').style.display='none';
  APP.confirmAction=null;
}

document.getElementById('confirmModalAccept').addEventListener('click',()=>{
  if(APP.confirmAction) APP.confirmAction();
});

function showStatusModal(title,message){
  document.getElementById('statusModalTitle').textContent=title;
  document.getElementById('statusModalMessage').textContent=message;
  document.getElementById('statusModalOverlay').style.display='flex';
  clearTimeout(APP.statusTimer);
  APP.statusTimer=setTimeout(closeStatusModal,1700);
}

function closeStatusModal(){
  document.getElementById('statusModalOverlay').style.display='none';
}

document.querySelectorAll('.modal-overlay').forEach(overlay=>
  overlay.addEventListener('click',e=>{
    if(e.target===overlay) overlay.style.display='none';
  })
);

boot();
</script>
</body>
</html>