const staticState={search:'',page:1,pageSize:5};

function renderStaticTable(key){
  const data=staticData[key];
  if(!data){ renderHome(); return; }

  const query=staticState.search.toLowerCase();
  const filtered=data.rows.filter(row=>
    row.some(cell=>String(cell).toLowerCase().includes(query))
  );

  const totalPages=Math.max(1,Math.ceil(filtered.length/staticState.pageSize));
  if(staticState.page>totalPages) staticState.page=totalPages;
  const start=(staticState.page-1)*staticState.pageSize;
  const paged=filtered.slice(start,start+staticState.pageSize);

  const pageButtons=()=>{
    if(totalPages<=1) return '';
    let b=`<button ${staticState.page===1?'disabled':''} onclick="staticChangePage(${staticState.page-1},'${key}')">‹</button>`;
    for(let i=1;i<=totalPages;i++) b+=`<button class="${i===staticState.page?'active':''}" onclick="staticChangePage(${i},'${key}')">${i}</button>`;
    b+=`<button ${staticState.page===totalPages?'disabled':''} onclick="staticChangePage(${staticState.page+1},'${key}')">›</button>`;
    return b;
  };

  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div>
          <h1>${escapeHtml(data.title)}</h1>
          <p>${escapeHtml(data.description)}</p>
        </div>
        <div class="table-actions">
          <button class="btn btn-success">+ Agregar</button>
        </div>
      </div>
      <div class="filter-box">
        <div class="filter-grid">
          <div class="field">
            <label>Buscar</label>
            <input id="staticSearchBox" type="text" placeholder="Buscar en la tabla..." value="${escapeHtml(staticState.search)}">
          </div>
          <div class="actions-inline" style="align-self:flex-end">
            <button class="btn btn-success" onclick="staticApplySearch('${key}')">Buscar</button>
            <button class="btn btn-secondary" onclick="staticClearSearch('${key}')">Limpiar</button>
          </div>
        </div>
      </div>
      <div class="table-tools">Mostrando ${filtered.length} registro${filtered.length!==1?'s':''}</div>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              ${data.columns.map(c=>`<th>${escapeHtml(c)}</th>`).join('')}
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            ${paged.length?paged.map(row=>`
              <tr>
                ${row.map(cell=>`<td>${escapeHtml(String(cell))}</td>`).join('')}
                <td>
                  <div class="actions-inline">
                    <button class="btn btn-warning" style="padding:7px 12px">Editar</button>
                    <button class="btn btn-danger" style="padding:7px 12px">Eliminar</button>
                  </div>
                </td>
              </tr>`).join(''):`<tr><td colspan="${data.columns.length+1}"><div class="empty">No hay registros para mostrar</div></td></tr>`}
          </tbody>
        </table>
      </div>
      <div class="pagination">${pageButtons()}</div>
    </div>`;
}

function staticApplySearch(key){
  const input=document.getElementById('staticSearchBox');
  staticState.search=input?input.value.trim():'';
  staticState.page=1;
  renderStaticTable(key);
}

function staticClearSearch(key){
  staticState.search=''; staticState.page=1;
  const input=document.getElementById('staticSearchBox');
  if(input) input.value='';
  renderStaticTable(key);
}

function staticChangePage(page,key){
  staticState.page=page;
  renderStaticTable(key);
}

async function loadStatic(moduleName){
  staticState.search=''; staticState.page=1;
  const key=APP.state.moduleKey;
  if(staticData[key]){ renderStaticTable(key); return; }

  // fallback original
  const res=await fetch(`/api/static/${key}`);
  const json=await res.json();
  const a=json.actions||{};
  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div><h1>${escapeHtml(moduleName)}</h1><p>Módulo del sistema.</p></div>
      </div>
      <div class="crud-actions">
        ${a.agregar?'<button class="btn btn-success">+ Agregar</button>':''}
        ${a.editar?'<button class="btn btn-warning">Editar</button>':''}
        ${a.eliminar?'<button class="btn btn-danger">Eliminar</button>':''}
        ${a.consulta?'<button class="btn btn-secondary">Consultar</button>':''}
        ${a.detalle?'<button class="btn btn-primary">Detalle</button>':''}
      </div>
      <div class="filter-box" style="margin-top:18px"><p>Esta pantalla muestra los botones permitidos para tu perfil.</p></div>
    </div>`;
}

function openDetailModal(title,html){
  document.getElementById('detailModalTitle').textContent=title;
  document.getElementById('detailModalBody').innerHTML=html;
  document.getElementById('detailModalOverlay').style.display='flex';
}
function closeDetailModal(){
  document.getElementById('detailModalOverlay').style.display='none';
  document.getElementById('detailModalBody').innerHTML='';
}
function openConfirmModal(title,message,onAccept){
  document.getElementById('confirmModalTitle').textContent=title;
  document.getElementById('confirmModalMessage').textContent=message;
  APP.confirmAction=onAccept;
  document.getElementById('confirmModalOverlay').style.display='flex';
}
function closeConfirmModal(){
  document.getElementById('confirmModalOverlay').style.display='none';
  APP.confirmAction=null;
}
document.getElementById('confirmModalAccept').addEventListener('click',()=>{if(APP.confirmAction)APP.confirmAction();});
function showStatusModal(title,message){
  document.getElementById('statusModalTitle').textContent=title;
  document.getElementById('statusModalMessage').textContent=message;
  document.getElementById('statusModalOverlay').style.display='flex';
  clearTimeout(APP.statusTimer);
  APP.statusTimer=setTimeout(closeStatusModal,2000);
}
function closeStatusModal(){document.getElementById('statusModalOverlay').style.display='none';}
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.style.display='none';}));

boot();
