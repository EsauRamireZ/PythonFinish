<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard · Mi Servidor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:      #1a102f;
      --navy-2:    #231447;
      --navy-3:    #2d1d5c;
      --slate:     #3c2a6e;

      --sky:       #7c3aed;      /* morado */
      --sky-light: #a78bfa;      /* lila */

      --gold:      #22c55e;      /* verde neón */
      --gold-lt:   #4ade80;

      --ink:       #22c55e;

      --muted:     #6b7280;
      --muted-lt:  #9ca3af;

      --bg:        #0b0b14;      /* fondo oscuro */
      --surface:   #111827;      /* cards oscuras */
      --surface-2: #1f2937;

      --border:    #374151;
      --border-2:  #4b5563;

      --success:   #22c55e;
      --danger:    #ef4444;
      --warn:      #f59e0b;
      --info:      #3b82f6;

      --shadow-sm: 0 2px 8px rgba(0,0,0,.4);
      --shadow-md: 0 8px 24px rgba(0,0,0,.5);
      --shadow-lg: 0 20px 50px rgba(0,0,0,.6);

      --radius-sm: 8px;
      --radius:    14px;
      --radius-lg: 20px;
      --radius-xl: 28px;

      --transition: 0.18s cubic-bezier(.4,0,.2,1);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--ink);
      min-height: 100vh;
      font-size: 15px;
      line-height: 1.5;
    }

    /* ── TOPBAR ──────────────────────────────── */
    .topbar {
      background: var(--navy);
      padding: 0 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 68px;
      position: sticky;
      top: 0;
      z-index: 200;
      box-shadow: 0 1px 0 rgba(255,255,255,.05), var(--shadow-lg);
    }

    .brand-left { display: flex; align-items: center; gap: 14px; }

    .logo-mini {
      width: 42px; height: 42px;
      border-radius: var(--radius-sm);
      background: linear-gradient(135deg, var(--sky), var(--sky-light));
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-family: 'DM Serif Display', serif;
      font-size: 20px;
      letter-spacing: -.5px;
      box-shadow: 0 4px 14px rgba(61,124,201,.40);
    }

    .brand-copy small {
      display: block;
      color: var(--muted-lt);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .brand-copy h2 {
      color: #fff;
      font-size: 18px;
      font-weight: 600;
      letter-spacing: -.3px;
    }

    .topbar-right { display: flex; align-items: center; gap: 16px; }

    .user-chip {
      display: flex; align-items: center; gap: 10px;
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.10);
      border-radius: 999px;
      padding: 6px 14px 6px 8px;
    }

    .user-avatar {
      width: 30px; height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--gold-lt));
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700;
      color: var(--navy);
    }

    .user-chip span { color: rgba(255,255,255,.85); font-size: 13.5px; font-weight: 500; }

    .logout-btn {
      border: none;
      background: rgba(255,255,255,.1);
      color: rgba(255,255,255,.8);
      border-radius: 999px;
      padding: 7px 16px;
      cursor: pointer;
      font-size: 13.5px;
      font-weight: 500;
      font-family: inherit;
      transition: background var(--transition), color var(--transition);
      text-decoration: none;
    }
    .logout-btn:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── NAV ─────────────────────────────────── */
    .main-nav {
      background: var(--navy-2);
      padding: 0 32px;
      display: flex;
      gap: 2px;
      border-bottom: 1px solid rgba(255,255,255,.05);
    }

    .nav-item { position: relative; }

    .nav-link {
      background: transparent;
      color: rgba(255,255,255,.60);
      border: none;
      padding: 14px 18px;
      font-size: 14px;
      font-weight: 500;
      font-family: inherit;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color var(--transition), border-color var(--transition);
      white-space: nowrap;
      display: flex; align-items: center; gap: 6px;
    }
    .nav-link:hover, .nav-link.active {
      color: #fff;
      border-bottom-color: var(--sky-light);
    }

    .dropdown-menu {
      display: none;
      position: absolute;
      top: calc(100% + 1px);
      left: 0;
      min-width: 220px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 0 var(--radius) var(--radius) var(--radius);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      z-index: 300;
    }
    .nav-item:hover .dropdown-menu { display: block; }

    .dropdown-link {
      width: 100%; border: none;
      background: transparent;
      color: var(--ink);
      text-align: left;
      padding: 12px 18px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      font-family: inherit;
      border-bottom: 1px solid var(--border);
      transition: background var(--transition), color var(--transition), padding-left var(--transition);
      display: flex; align-items: center; gap: 8px;
    }
    .dropdown-link:last-child { border-bottom: none; }
    .dropdown-link::before {
      content: '';
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--sky);
      opacity: 0;
      transition: opacity var(--transition);
    }
    .dropdown-link:hover, .dropdown-link.active {
      background: var(--surface-2);
      color: var(--sky);
      padding-left: 22px;
    }
    .dropdown-link:hover::before, .dropdown-link.active::before { opacity: 1; }

    /* ── LAYOUT ──────────────────────────────── */
    .main-content { padding: 28px 32px; max-width: 1400px; margin: 0 auto; }

    /* ── BREADCRUMB ──────────────────────────── */
    .breadcrumb {
      display: flex; align-items: center; gap: 8px;
      color: var(--muted); font-size: 13.5px; font-weight: 500;
      margin-bottom: 22px;
      padding: 10px 16px;
      background: var(--surface);
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      width: fit-content;
    }
    .crumb-link {
      color: var(--sky); font-weight: 600; cursor: pointer; text-decoration: none;
      transition: color var(--transition);
    }
    .crumb-link:hover { color: var(--sky-light); }
    .breadcrumb span { color: var(--muted); }
    .breadcrumb-sep { color: var(--border-2); }

    /* ── CARDS ───────────────────────────────── */
    .module-card {
      background: var(--surface);
      border-radius: var(--radius-lg);
      padding: 28px;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--border);
    }

    .module-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      gap: 16px; flex-wrap: wrap; margin-bottom: 24px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }
    .module-header h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 26px; color: var(--success);
      letter-spacing: -.3px; margin-bottom: 4px;
    }
    .module-header p { color: var(--muted); font-size: 14px; }

    /* ── HOME DASHBOARD ──────────────────────── */
    .dashboard-welcome { display: grid; grid-template-columns: 1fr 380px; gap: 20px; }

    .hero-panel {
      background: linear-gradient(135deg, var(--navy) 0%, var(--slate) 100%);
      border-radius: var(--radius-xl);
      padding: 40px;
      color: #fff;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
    }
    .hero-panel::before {
      content: '';
      position: absolute;
      width: 300px; height: 300px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(61,124,201,.30) 0%, transparent 70%);
      top: -80px; right: -60px;
      pointer-events: none;
    }
    .hero-panel::after {
      content: '';
      position: absolute;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(201,168,76,.15) 0%, transparent 70%);
      bottom: -40px; left: 20px;
      pointer-events: none;
    }
    .hero-panel h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 38px;
      font-weight: 400;
      color: #fff;
      letter-spacing: -.5px;
      margin-bottom: 12px;
      position: relative; z-index: 1;
    }
    .hero-panel p {
      color: rgba(255,255,255,.65);
      font-size: 15px;
      line-height: 1.7;
      max-width: 480px;
      position: relative; z-index: 1;
    }
    .welcome-name {
      display: inline-flex; align-items: center; gap: 10px;
      margin-top: 28px;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.18);
      color: #fff;
      padding: 10px 18px;
      border-radius: 999px;
      font-size: 14px; font-weight: 600;
      position: relative; z-index: 1;
    }
    .welcome-name-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--gold-lt);
      box-shadow: 0 0 8px var(--gold);
    }

    .info-panel {
      background: var(--surface);
      border-radius: var(--radius-xl);
      padding: 32px;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-md);
    }
    .info-panel-header {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 20px;
    }
    .info-panel-icon {
      width: 38px; height: 38px;
      background: linear-gradient(135deg, rgba(61,124,201,.12), rgba(61,124,201,.06));
      border: 1px solid rgba(61,124,201,.20);
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }
    .info-panel h3 {
      color: var(--navy); font-size: 16px; font-weight: 600;
    }
    .info-list { display: flex; flex-direction: column; gap: 12px; }
    .info-item {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      display: flex; flex-direction: column; gap: 3px;
    }
    .info-item-label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
    .info-item-value { font-size: 14.5px; font-weight: 500; color: var(--ink); }

    /* ── FILTER BOX ──────────────────────────── */
    .filter-box {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
      margin-bottom: 20px;
    }
    .filter-grid { display: flex; align-items: flex-end; gap: 16px; flex-wrap: wrap; }
    .field { display: flex; flex-direction: column; gap: 6px; min-width: 200px; flex: 1; }
    .field label { font-size: 12.5px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
    .field input, .field select {
      width: 100%; height: 42px;
      border: 1px solid var(--border-2);
      border-radius: var(--radius-sm);
      padding: 0 14px;
      background: var(--surface);
      color: var(--ink);
      font-family: inherit; font-size: 14px;
      outline: none;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .field textarea {
      width: 100%; min-height: 100px;
      border: 1px solid var(--border-2);
      border-radius: var(--radius-sm);
      padding: 12px 14px;
      background: var(--surface); color: var(--ink);
      font-family: inherit; font-size: 14px;
      outline: none; resize: vertical;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: var(--sky);
      box-shadow: 0 0 0 3px rgba(61,124,201,.12);
    }
    .field input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--sky); }
    .field-full { grid-column: 1 / -1; }

    /* ── TABLE ───────────────────────────────── */
    .table-tools {
      font-size: 12.5px; font-weight: 600; color: var(--muted);
      text-transform: uppercase; letter-spacing: .06em;
      margin-bottom: 12px;
    }
    .table-responsive { overflow: auto; border-radius: var(--radius); border: 1px solid var(--border); }
    .data-table { width: 100%; border-collapse: collapse; background: var(--surface); }
    .data-table thead th {
      background: var(--navy);
      color: rgba(255,255,255,.85);
      padding: 13px 16px;
      text-align: left;
      font-size: 12.5px; font-weight: 600;
      text-transform: uppercase; letter-spacing: .06em;
      white-space: nowrap;
    }
    .data-table thead th:first-child { border-radius: var(--radius) 0 0 0; }
    .data-table thead th:last-child { border-radius: 0 var(--radius) 0 0; }
    .data-table tbody td {
      padding: 13px 16px;
      border-bottom: 1px solid var(--border);
      color: #334155; font-size: 14px;
      vertical-align: middle;
    }
    .data-table tbody tr:last-child td { border-bottom: none; }
    .data-table tbody tr { transition: background var(--transition); }
    .data-table tbody tr:hover { background: #f5f9ff; }

    /* ── PAGINATION ──────────────────────────── */
    .pagination {
      display: flex; justify-content: center; gap: 6px;
      flex-wrap: wrap; margin-top: 22px;
    }
    .pagination button {
      background: var(--surface);
      border: 1px solid var(--border-2);
      border-radius: var(--radius-sm);
      padding: 8px 14px;
      cursor: pointer; font-weight: 600; font-size: 13.5px;
      color: var(--slate); font-family: inherit;
      transition: all var(--transition);
    }
    .pagination button:hover:not(:disabled) { background: var(--surface-2); border-color: var(--sky); color: var(--sky); }
    .pagination button:disabled { opacity: .4; cursor: not-allowed; }
    .pagination button.active { background: var(--sky); border-color: var(--sky); color: #fff; box-shadow: 0 4px 12px rgba(61,124,201,.35); }

    /* ── BUTTONS ─────────────────────────────── */
    .btn {
      border: none; border-radius: var(--radius-sm);
      padding: 9px 16px;
      font-weight: 600; font-size: 13.5px; font-family: inherit;
      cursor: pointer; text-decoration: none;
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      transition: all var(--transition);
      white-space: nowrap;
    }
    .btn-success { background: var(--sky); color: #fff; box-shadow: 0 2px 8px rgba(61,124,201,.25); }
    .btn-success:hover { background: var(--sky-light); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(61,124,201,.35); }
    .btn-secondary { background: var(--surface); color: var(--muted); border: 1px solid var(--border-2); }
    .btn-secondary:hover { background: var(--surface-2); color: var(--ink); }
    .btn-primary { background: var(--info); color: #fff; }
    .btn-primary:hover { opacity: .88; }
    .btn-danger { background: #fff0f0; color: var(--danger); border: 1px solid #fdd; }
    .btn-danger:hover { background: var(--danger); color: #fff; }
    .btn-warning { background: #fffbeb; color: var(--warn); border: 1px solid #fde68a; }
    .btn-warning:hover { background: var(--warn); color: #fff; }

    /* ── BADGE ───────────────────────────────── */
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px; font-weight: 600;
      background: rgba(61,124,201,.10); color: var(--sky);
      border: 1px solid rgba(61,124,201,.20);
    }

    /* ── EMPTY STATE ─────────────────────────── */
    .empty {
      padding: 48px 24px; text-align: center; color: var(--muted);
      font-size: 14px;
    }
    .empty::before { content: '⊘'; display: block; font-size: 32px; margin-bottom: 10px; opacity: .3; }

    /* ── TABLE IMAGE ─────────────────────────── */
    .table-image {
      width: 38px; height: 38px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--border-2);
    }

    /* ── FORM ────────────────────────────────── */
    .form-screen { display: grid; gap: 20px; }
    .form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .check-card {
      display: flex; align-items: center; gap: 10px;
      padding: 14px 16px;
      border: 1px solid var(--border-2);
      border-radius: var(--radius); background: var(--surface-2);
      cursor: pointer; transition: border-color var(--transition), background var(--transition);
      font-size: 14px; font-weight: 500; color: var(--ink);
    }
    .check-card:hover { border-color: var(--sky); background: #f0f7ff; }

    /* ── DETAIL ──────────────────────────────── */
    .detail-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .detail-box {
      padding: 12px 14px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface-2);
      font-size: 14px; color: var(--ink);
      word-break: break-word; min-height: 44px;
      display: flex; align-items: center;
    }
    .detail-image { width: 110px; height: 110px; border-radius: var(--radius); object-fit: cover; border: 2px solid var(--border-2); }

    /* ── PERMISSIONS ─────────────────────────── */
    .perm-check { width: 17px; height: 17px; accent-color: var(--sky); cursor: pointer; }
    .perm-save { white-space: nowrap; }

    /* ── ACTIONS ─────────────────────────────── */
    .actions-inline, .crud-actions, .modal-actions, .table-actions {
      display: flex; gap: 8px; flex-wrap: wrap;
    }

    /* ── MODALS ──────────────────────────────── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(15,28,46,.55);
      backdrop-filter: blur(4px);
      display: none; align-items: center; justify-content: center;
      padding: 20px; z-index: 999;
    }
    .modal-box {
      width: min(580px, 100%);
      background: var(--surface);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      border: 1px solid var(--border);
      animation: modalIn .22s cubic-bezier(.4,0,.2,1);
    }
    .modal-box.modal-sm { width: min(420px, 100%); }
    @keyframes modalIn {
      from { opacity: 0; transform: translateY(16px) scale(.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .modal-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center; gap: 10px;
      background: var(--surface-2);
    }
    .modal-header h2 { color: var(--navy); font-size: 18px; font-weight: 600; }
    .modal-close {
      border: 1px solid var(--border-2);
      background: var(--surface);
      width: 34px; height: 34px;
      border-radius: var(--radius-sm);
      font-weight: 700; cursor: pointer; font-size: 14px;
      color: var(--muted); transition: all var(--transition);
    }
    .modal-close:hover { background: #fff0f0; color: var(--danger); border-color: #fdd; }
    .modal-body { padding: 24px; }
    .modal-body p { color: var(--muted); line-height: 1.7; font-size: 14.5px; }

    /* ── STATUS PILL ─────────────────────────── */
    .status-pill {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 12.5px; font-weight: 600;
    }
    .status-pill.active { background: #ecfdf5; color: var(--success); border: 1px solid #a7f3d0; }
    .status-pill.inactive { background: #fff7ed; color: var(--warn); border: 1px solid #fed7aa; }

    /* ── RESPONSIVE ──────────────────────────── */
    @media (max-width: 1024px) {
      .dashboard-welcome { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .topbar { padding: 0 16px; }
      .main-nav { padding: 0 16px; }
      .main-content { padding: 20px 16px; }
      .module-card { padding: 20px; }
      .form-grid, .detail-grid { grid-template-columns: 1fr; }
      .data-table { min-width: 720px; }
      .hero-panel h1 { font-size: 28px; }
      .user-chip span { display: none; }
    }
    /* ── LAYOUT SIDEBAR ───────────────────────── */
.layout {
  display: flex;
}

/* SIDEBAR */
.sidebar {
  width: 240px;
  min-height: calc(100vh - 68px);
  background: var(--navy-2);
  border-right: 1px solid rgba(255,255,255,.05);
  padding-top: 10px;
}

/* MENÚ */
.sidebar .nav-item {
  width: 100%;
}

.sidebar .nav-link {
  width: 100%;
  justify-content: flex-start;
  padding: 14px 20px;
  border-bottom: 1px solid rgba(255,255,255,.05);
}

/* ACTIVO */
.sidebar .nav-link.active {
  background: rgba(124,58,237,.2);
  border-left: 4px solid var(--sky);
}

/* DROPDOWN como lista */
.sidebar .dropdown-menu {
  position: static;
  display: block;
  background: transparent;
  border: none;
  box-shadow: none;
}

/* SUBMENÚ */
.sidebar .dropdown-link {
  padding-left: 30px;
  background: transparent;
  color: rgba(255,255,255,.7);
}

.sidebar .dropdown-link:hover {
  background: rgba(255,255,255,.05);
  color: #fff;
}
  </style>
</head>
<body>
  <div class="app-shell">

    <header class="topbar">
      <div class="brand-left">
        <div class="brand-copy">
          <h1>Mi Proyecto</h1>
        </div>
      </div>
      <div class="topbar-right">

        <div class="welcome-name">
          <div class="welcome-name-dot">
          <span id="topUserLabel"><%= user.strNombreUsuario %></span>
        </div>
        
        <a class="logout-btn" href="/logout">Cerrar sesión</a>
      </div>
    </header>

    <div class="layout">
  <aside class="sidebar" id="mainNav"></aside>

  <main class="main-content">
    <div id="breadcrumbs" class="breadcrumb">
      <span>Inicio</span>
    </div>
    <div id="moduleContent"></div>
  </main>
</div>
  </div>

  <!-- DETAIL MODAL -->
  <div class="modal-overlay" id="detailModalOverlay">
    <div class="modal-box">
      <div class="modal-header">
        <h2 id="detailModalTitle">Detalle</h2>
        <button class="modal-close" type="button" onclick="closeDetailModal()">✕</button>
      </div>
      <div class="modal-body" id="detailModalBody"></div>
    </div>
  </div>

  <!-- CONFIRM MODAL -->
  <div class="modal-overlay" id="confirmModalOverlay">
    <div class="modal-box modal-sm">
      <div class="modal-header">
        <h2 id="confirmModalTitle">Confirmación</h2>
        <button class="modal-close" type="button" onclick="closeConfirmModal()">✕</button>
      </div>
      <div class="modal-body">
        <p id="confirmModalMessage"></p>
        <div class="modal-actions" style="justify-content:flex-end;margin-top:22px">
          <button type="button" class="btn btn-secondary" onclick="closeConfirmModal()">Cancelar</button>
          <button type="button" class="btn btn-danger" id="confirmModalAccept">Eliminar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- STATUS MODAL -->
  <div class="modal-overlay" id="statusModalOverlay">
    <div class="modal-box modal-sm">
      <div class="modal-header">
        <h2 id="statusModalTitle">Listo</h2>
        <button class="modal-close" type="button" onclick="closeStatusModal()">✕</button>
      </div>
      <div class="modal-body">
        <p id="statusModalMessage"></p>
      </div>
    </div>
  </div>

<script>
const APP={
  menus:<%- JSON.stringify(menus) %>,
  permissions:<%- JSON.stringify(permissions) %>,
  initialModule:<%- JSON.stringify(typeof initialModule !== 'undefined' ? initialModule : null) %>,
  user:<%- JSON.stringify(user) %>,
  catalogs:null,
  state:{view:'home',moduleKey:null,moduleName:'',menuName:'',page:1,search:'',editingId:null,permissionFilterPerfil:'',permissionRows:[],permissionTotalPages:1},
  confirmAction:null,statusTimer:null
};

const schemas={
  perfil:{
    title:'Perfiles',singleTitle:'Perfil',
    description:'Administración de perfiles del sistema.',
    endpoint:'/api/perfiles',search:true,
    searchLabel:'Perfil',searchPlaceholder:'Buscar perfil...',
    columns:[
      {key:'strNombrePerfil',label:'Nombre de perfil'},
      {key:'bitAdministrador',label:'Administrador',render:v=>v?'<span class="badge">✓ Sí</span>':'<span style="color:var(--muted)">No</span>'}
    ],
    detailLabels:{strNombrePerfil:'Perfil',bitAdministrador:'Administrador'},
    form:[
      {name:'strNombrePerfil',label:'Perfil',type:'text',maxLength:80,required:true},
      {name:'bitAdministrador',label:'Administrador',type:'checkbox'}
    ]
  },
  modulo:{
    title:'Módulos',singleTitle:'Módulo',
    description:'Administración de módulos del sistema.',
    endpoint:'/api/modulos',search:true,
    searchLabel:'Módulo',searchPlaceholder:'Buscar módulo...',
    columns:[
      {key:'strNombreModulo',label:'Nombre de módulo'},
      {key:'strClaveModulo',label:'Clave'}
    ],
    detailLabels:{strNombreModulo:'Módulo',strClaveModulo:'Clave',strRuta:'Ruta'},
    form:[
      {name:'strNombreModulo',label:'Módulo',type:'text',maxLength:80,required:true},
      {name:'strClaveModulo',label:'Clave',type:'text',maxLength:50,required:true},
      {name:'strRuta',label:'Ruta',type:'text',maxLength:120,required:true}
    ]
  },
  permisos_perfil:{
    title:'Permisos por perfil',singleTitle:'Permiso',
    description:'Asignación de permisos por perfil con guardado por fila.',
    endpoint:'/api/permisos-perfil',search:false,
    columns:[
      {key:'strNombrePerfil',label:'Perfil'},
      {key:'strNombreModulo',label:'Módulo'}
    ],
    detailLabels:{strNombrePerfil:'Perfil',strNombreModulo:'Módulo',bitAgregar:'Agregar',bitEditar:'Editar',bitConsulta:'Consultar',bitEliminar:'Eliminar',bitDetalle:'Detalle'},
    form:[
      {name:'idPerfil',label:'Perfil',type:'select',optionsKey:'perfiles',required:true,textKey:'strNombrePerfil'},
      {name:'idModulo',label:'Módulo',type:'select',optionsKey:'modulos',required:true,textKey:'strNombreModulo'}
    ]
  },
  usuario:{
    title:'Usuarios',singleTitle:'Usuario',
    description:'Administración de usuarios del sistema.',
    endpoint:'/api/usuarios',search:true,
    searchLabel:'Usuario',searchPlaceholder:'Buscar usuario o correo...',
    columns:[
      {key:'strImagen',label:'Foto',render:v=>v?`<img class="table-image" src="${escapeAttr(v)}" alt="Foto">`:'<span class="badge">Sin foto</span>'},
      {key:'strNombreUsuario',label:'Usuario'},
      {key:'strNombrePerfil',label:'Perfil'},
      {key:'strCorreo',label:'Correo'},
      {key:'strNumeroCelular',label:'Teléfono'},
      {key:'strNombreEstado',label:'Estado'}
    ],
    detailLabels:{strNombreUsuario:'Usuario',idPerfil:'Perfil',strPwd:'Contraseña',idEstadoUsuario:'Estado',strCorreo:'Correo',strNumeroCelular:'Teléfono',strImagen:'Foto'},
    form:[
      {name:'strNombreUsuario',label:'Usuario',type:'text',maxLength:80,required:true},
      {name:'idPerfil',label:'Perfil',type:'select',optionsKey:'perfiles',required:true,textKey:'strNombrePerfil'},
      {name:'strPwd',label:'Contraseña',type:'password',maxLength:120,required:true},
      {name:'idEstadoUsuario',label:'Estado',type:'select',optionsKey:'estados',required:true,textKey:'strNombreEstado'},
      {name:'strCorreo',label:'Correo',type:'email',maxLength:120,required:true},
      {name:'strNumeroCelular',label:'Teléfono',type:'text',maxLength:10,required:true},
      {name:'strImagen',label:'Foto',type:'file',accept:'image/png,image/jpeg,image/jpg,image/webp'}
    ]
  }
};

const moduleRoutes={
  perfil:'/seguridad/perfil',
  modulo:'/seguridad/modulo',
  permisos_perfil:'/seguridad/permisos-perfil',
  usuario:'/seguridad/usuario'
};

function getModuleUrl(mod){ return moduleRoutes[mod?.clave] || mod?.ruta || '#'; }

function escapeHtml(v){return String(v??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));}
function escapeAttr(v){return escapeHtml(v);}
function boolToText(v){return v?'Sí':'No';}
function getPermission(){return APP.permissions[APP.state.moduleKey]||{};}

function renderPagination(totalPages,currentPage,callbackName){
  totalPages=Number(totalPages)||1; currentPage=Number(currentPage)||1;
  if(totalPages<=1) return '';
  let html='';
  html+=`<button ${currentPage===1?'disabled':''} onclick="${callbackName}(${currentPage-1})">‹</button>`;
  for(let i=1;i<=totalPages;i++) html+=`<button class="${i===currentPage?'active':''}" onclick="${callbackName}(${i})">${i}</button>`;
  html+=`<button ${currentPage===totalPages?'disabled':''} onclick="${callbackName}(${currentPage+1})">›</button>`;
  return html;
}

async function loadPermissionRows(page=1){
  const profileId=Number(APP.state.permissionFilterPerfil||0);
  if(!profileId){
    APP.state.permissionRows=[];
    APP.state.permissionTotalPages=1;
    APP.state.page=1;
    return;
  }
  const res=await fetch(`/api/permisos-perfil?page=${page}&idPerfil=${profileId}`);
  const json=await res.json();
  APP.state.permissionRows=json.data||[];
  APP.state.permissionTotalPages=json.totalPages||1;
  APP.state.page=json.page||page;
}

async function applyPermissionFilters(){
  const pa=document.getElementById('permissionFilterPerfil');
  APP.state.permissionFilterPerfil=pa?pa.value.trim():'';
  APP.state.page=1;
  await loadPermissionRows(1);
  renderPermissionsTable(schemas.permisos_perfil,APP.state.permissionRows||[],APP.state.permissionTotalPages||1);
}

async function clearPermissionFilters(){
  APP.state.permissionFilterPerfil='';
  APP.state.page=1;
  APP.state.permissionRows=[];
  APP.state.permissionTotalPages=1;
  const pa=document.getElementById('permissionFilterPerfil');
  if(pa) pa.value='';
  renderPermissionsTable(schemas.permisos_perfil,APP.state.permissionRows||[],1);
}

async function loadPermissionPage(page){
  APP.state.page=page;
  await loadPermissionRows(page);
  renderPermissionsTable(schemas.permisos_perfil,APP.state.permissionRows||[],APP.state.permissionTotalPages||1);
}

function setBreadcrumb(){
  const homeLink=APP.initialModule ? '/' : 'javascript:void(0)';
  const homeAction=APP.initialModule ? '' : ' onclick="renderHome()"';
  const crumbs=[`<a href="${homeLink}"${homeAction} class="crumb-link">Inicio</a>`];
  if(APP.state.menuName) crumbs.push(`<span class="breadcrumb-sep">›</span><span>${escapeHtml(APP.state.menuName)}</span>`);
  if(APP.state.moduleName) crumbs.push(`<span class="breadcrumb-sep">›</span><span>${escapeHtml(APP.state.moduleName)}</span>`);
  if(APP.state.view==='create') crumbs.push(`<span class="breadcrumb-sep">›</span><span>Agregar</span>`);
  if(APP.state.view==='edit') crumbs.push(`<span class="breadcrumb-sep">›</span><span>Editar</span>`);
  document.getElementById('breadcrumbs').innerHTML=crumbs.join('');
}

function buildMenus(){
  const nav=document.getElementById('mainNav');
  nav.innerHTML='';
  APP.menus.forEach(menu=>{
    const visible=(menu.modulos||[]).filter(mod=>{
      const p=APP.permissions[mod.clave]||{};
      return p.agregar||p.editar||p.consulta||p.eliminar||p.detalle;
    });
    if(!visible.length) return;

    const item=document.createElement('div');
    item.className='nav-item';

    const button=document.createElement('button');
    button.className='nav-link';
    button.textContent=menu.nombre;

    const dropdown=document.createElement('div');
    dropdown.className='dropdown-menu';

    visible.forEach(mod=>{
      const link=document.createElement('a');
      link.className='dropdown-link';
      link.textContent=mod.nombre;
      link.href=getModuleUrl(mod);
      dropdown.appendChild(link);
    });

    item.append(button, dropdown);
    nav.appendChild(item);
  });
}

async function boot(){
  const res=await fetch('/api/catalogos/base');
  APP.catalogs=await res.json();

  const u=APP.user;
  const av=document.getElementById('topUserAvatar');
  if(av && u.strNombreUsuario) av.textContent=u.strNombreUsuario.charAt(0).toUpperCase();
  const lbl=document.getElementById('topUserLabel');
  if(lbl) lbl.textContent=`${u.strNombreUsuario} · ${u.strNombrePerfil}`;

  buildMenus();

  if(!APP.initialModule || !APP.initialModule.moduleKey) return renderHome();

  APP.state.menuName=APP.initialModule.menuName||'';
  APP.state.moduleName=APP.initialModule.moduleName||'';
  APP.state.moduleKey=APP.initialModule.moduleKey;
  APP.state.view='list';

  highlightNav();
  setBreadcrumb();
  await loadList(1);
}

function highlightNav(){
  document.querySelectorAll('.dropdown-link').forEach(el=>el.classList.toggle('active',el.textContent===APP.state.moduleName&&APP.state.view!=='home'));
  document.querySelectorAll('.nav-link').forEach(el=>el.classList.toggle('active',el.textContent.includes(APP.state.menuName)&&APP.state.view!=='home'));
}

function renderHome(){
  APP.state.view='home'; APP.state.menuName=''; APP.state.moduleName='';
  APP.state.moduleKey=null; APP.state.page=1; APP.state.search=''; APP.state.editingId=null;
  highlightNav(); setBreadcrumb();
  const u=APP.user;
  document.getElementById('moduleContent').innerHTML=`
    <div class="dashboard-welcome">
      <section class="hero-panel">
        <h1>Bienvenido de nuevo</h1>
        <p>Has entrado de forma correcta. Ahora puedes disponer de los modulos dependiendo de los permisos de tu perfil.</p>
        
      </section>
      <aside class="info-panel">
        <div class="info-panel-header">
          <h3>Datos de acceso</h3>
        </div>
        <div class="info-list">
          <div class="info-item">
            <span class="info-item-label">Perfil</span>
            <span class="info-item-value">${escapeHtml(u.strNombrePerfil||'')}</span>
          </div>
          <div class="info-item">
            <span class="info-item-label">Correo</span>
            <span class="info-item-value">${escapeHtml(u.strCorreo||'')}</span>
          </div>
          <div class="info-item">
            <span class="info-item-label">Teléfono</span>
            <span class="info-item-value">${escapeHtml(u.strNumeroCelular||'')}</span>
          </div>
        </div>
      </aside>
    </div>`;
}


function renderStaticModule(){
  const p=getPermission();
  highlightNav();
  setBreadcrumb();
  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div>
          <h1>${escapeHtml(APP.state.moduleName || 'Módulo')}</h1>
          <p>Módulo del sistema.</p>
        </div>
      </div>

      <div class="table-actions" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;">
        ${p.agregar ? `<button type="button" class="btn btn-success">+ Agregar</button>` : ''}
        ${p.editar ? `<button type="button" class="btn btn-warning">Editar</button>` : ''}
        ${p.eliminar ? `<button type="button" class="btn btn-danger">Eliminar</button>` : ''}
        ${p.consulta ? `<button type="button" class="btn btn-secondary">Consultar</button>` : ''}
        ${p.detalle ? `<button type="button" class="btn btn-primary">Detalle</button>` : ''}
      </div>

      <div class="detail-box" style="line-height:1.8;min-height:74px;align-items:flex-start;padding-top:18px;">
        Aqui solo se muestran los botenes permitidos.
      </div>
    </div>`;
}


async function loadList(page=1){
  APP.state.view='list'; APP.state.page=page; APP.state.editingId=null; setBreadcrumb();
  const schema=schemas[APP.state.moduleKey];
  if(!schema) return renderStaticModule();
  if(APP.state.moduleKey==='permisos_perfil'){
    await loadPermissionRows(APP.state.page||1);
    renderPermissionsTable(schema,APP.state.permissionRows||[],APP.state.permissionTotalPages||1);
    return;
  }
  const q=schema.search?`?page=${page}&search=${encodeURIComponent(APP.state.search||'')}`:`?page=${page}`;
  const res=await fetch(schema.endpoint+q);
  const json=await res.json();
  renderList(schema,json.data||[],json.totalPages||1);
}

function renderList(schema,rows,totalPages){
  if(APP.state.moduleKey==='permisos_perfil') return renderPermissionsTable(schema,rows,totalPages);
  const p=getPermission();
  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div>
          <h1>${escapeHtml(schema.title)}</h1>
          <p>${escapeHtml(schema.description)}</p>
        </div>
        <div class="table-actions">
          ${p.agregar?`<button class="btn btn-success" onclick="openCreateForm()">+ Agregar</button>`:''}
        </div>
      </div>
      ${schema.search?`
      <div class="filter-box">
        <div class="filter-grid">
          <div class="field">
            <label>${escapeHtml(schema.searchLabel)}</label>
            <input id="searchBox" type="text" placeholder="${escapeHtml(schema.searchPlaceholder)}" value="${escapeHtml(APP.state.search)}">
          </div>
          <div class="actions-inline" style="align-self:flex-end">
            <button class="btn btn-success" onclick="applySearch()">Buscar</button>
            <button class="btn btn-secondary" onclick="clearSearch()">Limpiar</button>
          </div>
        </div>
      </div>`:''}
      <div class="table-tools">Registros encontrados</div>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              ${schema.columns.map(c=>`<th>${escapeHtml(c.label)}</th>`).join('')}
              <th>Detalle</th><th>Editar</th><th>Eliminar</th>
            </tr>
          </thead>
          <tbody>
            ${rows.length?rows.map(row=>`
              <tr>
                ${schema.columns.map(c=>`<td>${c.render?c.render(row[c.key],row):escapeHtml(row[c.key]??'')}</td>`).join('')}
                <td>${p.detalle?`<button class="btn btn-primary" onclick="viewRecord(${row.id})">Ver</button>`:''}</td>
                <td>${p.editar?`<button class="btn btn-warning" onclick="openEditForm(${row.id})">Editar</button>`:''}</td>
                <td>${p.eliminar?`<button class="btn btn-danger" onclick="confirmDelete(${row.id})">Eliminar</button>`:''}</td>
              </tr>`).join(''):`<tr><td colspan="${schema.columns.length+3}"><div class="empty">No hay registros para mostrar</div></td></tr>`}
          </tbody>
        </table>
      </div>
      <div class="pagination">${renderPagination(totalPages,APP.state.page,'loadList')}</div>
    </div>`;
}

function renderPermissionsTable(schema,rows,totalPages){
  const p=getPermission();
  const profileId=Number(APP.state.permissionFilterPerfil||0);
  const profileOptions=(APP.catalogs?.perfiles||[]).map(perfil=>`<option value="${perfil.id}" ${String(perfil.id)===String(profileId)?'selected':''}>${escapeHtml(perfil.strNombrePerfil)}</option>`).join('');
  const selectedProfile=(APP.catalogs?.perfiles||[]).find(perfil=>String(perfil.id)===String(profileId));

  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card">
      <div class="module-header">
        <div>
          <h1>${escapeHtml(schema.title)}</h1>
          <p>${escapeHtml(schema.description)}</p>
        </div>
      </div>
      <div class="filter-box">
        <div class="filter-grid">
          <div class="field" style="max-width:560px;flex:0 0 560px;">
            <label>Filtrar por perfil</label>
            <select id="permissionFilterPerfil" onchange="applyPermissionFilters()">
              <option value="">— Todos los perfiles —</option>
              ${profileOptions}
            </select>
          </div>
          <div class="actions-inline" style="align-self:flex-end">
            <button class="btn btn-secondary" type="button" onclick="clearPermissionFilters()">Limpiar</button>
          </div>
          ${selectedProfile?`<div class="badge" style="height:42px;align-self:flex-end;display:inline-flex;">Perfil: ${escapeHtml(selectedProfile.strNombrePerfil)}</div>`:''}
        </div>
      </div>

      ${!profileId?`
        <div class="table-responsive">
          <table class="data-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Módulo</th>
                <th>Agregar</th>
                <th>Editar</th>
                <th>Consulta</th>
                <th>Eliminar</th>
                <th>Detalle</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td colspan="8">
                  <div class="empty" style="padding:60px 24px;">Selecciona un perfil para ver y editar sus permisos</div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>`:`
        <div class="table-responsive">
          <table class="data-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Módulo</th>
                <th>Agregar</th>
                <th>Editar</th>
                <th>Consulta</th>
                <th>Eliminar</th>
                <th>Detalle</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              ${(rows||[]).length?(rows||[]).map((row,index)=>`
                <tr>
                  <td>${((APP.state.page-1)*5)+(index+1)}</td>
                  <td>${escapeHtml(row.strNombreModulo)}</td>
                  <td><input class="perm-check" type="checkbox" data-field="bitAgregar" ${row.bitAgregar?'checked':''}></td>
                  <td><input class="perm-check" type="checkbox" data-field="bitEditar" ${row.bitEditar?'checked':''}></td>
                  <td><input class="perm-check" type="checkbox" data-field="bitConsulta" ${row.bitConsulta?'checked':''}></td>
                  <td><input class="perm-check" type="checkbox" data-field="bitEliminar" ${row.bitEliminar?'checked':''}></td>
                  <td><input class="perm-check" type="checkbox" data-field="bitDetalle" ${row.bitDetalle?'checked':''}></td>
                  <td>
                    <div class="table-actions">
                      ${p.editar?`<button class="btn btn-success perm-save" onclick="savePermissionRow(this,${row.id||0},${row.idPerfil},${row.idModulo})">Guardar</button>`:''}
                      ${p.detalle?`<button class="btn btn-primary" onclick="viewPermissionRecord(' ${encodeURIComponent(JSON.stringify({id:row.id||0,idPerfil:row.idPerfil,idModulo:row.idModulo,strNombrePerfil:row.strNombrePerfil,strNombreModulo:row.strNombreModulo,bitAgregar:!!row.bitAgregar,bitEditar:!!row.bitEditar,bitConsulta:!!row.bitConsulta,bitEliminar:!!row.bitEliminar,bitDetalle:!!row.bitDetalle}))} '.trim())">Ver</button>`:''}
                      ${p.eliminar?`<button class="btn btn-danger" ${row.id?`onclick="confirmPermissionDelete(${row.id})"`:'disabled'}>Eliminar</button>`:''}
                    </div>
                  </td>
                </tr>`).join(''):`<tr><td colspan="8"><div class="empty">No hay módulos para mostrar</div></td></tr>`}
            </tbody>
          </table>
        </div>
        <div class="pagination">${renderPagination(totalPages,APP.state.page,'loadPermissionPage')}</div>
      `}
    </div>`;
}

function applySearch(){
  const input=document.getElementById('searchBox');
  APP.state.search=input?input.value.trim():'';
  loadList(1);
}

function clearSearch(){
  APP.state.search='';
  const input=document.getElementById('searchBox');
  if(input) input.value='';
  loadList(1);
}

async function openCreateForm(){
  APP.state.view='create'; APP.state.editingId=null;
  if(APP.state.moduleKey==='usuario'||APP.state.moduleKey==='permisos_perfil'){
    const catRes=await fetch('/api/catalogos/base');
    APP.catalogs=await catRes.json();
  }
  setBreadcrumb(); renderForm();
}

async function openEditForm(id){
  APP.state.view='edit'; APP.state.editingId=id;
  if(APP.state.moduleKey==='usuario'||APP.state.moduleKey==='permisos_perfil'){
    const catRes=await fetch('/api/catalogos/base');
    APP.catalogs=await catRes.json();
  }
  setBreadcrumb(); renderForm(await getRecord(id));
}

async function getRecord(id){
  const schema=schemas[APP.state.moduleKey];
  const res=await fetch(`${schema.endpoint}/${id}`);
  const json=await res.json();
  return json.data||{};
}

function renderForm(data={}){
  const schema=schemas[APP.state.moduleKey];
  const title=APP.state.view==='edit'?`Editar ${schema.singleTitle}`:`Agregar ${schema.singleTitle}`;
  const p=getPermission();
  document.getElementById('moduleContent').innerHTML=`
    <div class="module-card form-screen">
      <div class="module-header">
        <div>
          <h1>${escapeHtml(title)}</h1>
          <p>Complete el formulario y presione Guardar para continuar.</p>
        </div>
      </div>
      <form id="entityForm">
        <input type="hidden" name="id" value="${data.id||''}">
        <div class="form-grid">
          ${schema.form.map(field=>renderField(field,data,schema)).join('')}
        </div>
        <div class="modal-actions" style="justify-content:flex-end;margin-top:24px">
          <button type="button" class="btn btn-secondary" onclick="loadList(${APP.state.page||1})">Cancelar</button>
          ${(APP.state.view==='create'&&p.agregar)||(APP.state.view==='edit'&&p.editar)?'<button type="submit" class="btn btn-success">Guardar cambios</button>':''}
        </div>
      </form>
    </div>`;
  document.getElementById('entityForm').onsubmit=saveRecord;
}

function renderField(field,data,schema){
  if(field.type==='checkbox'){
    return `<label class="check-card ${schema.title==='Permisos por perfil'?'':'field-full'}">
      <input type="checkbox" name="${field.name}" ${data[field.name]?'checked':''}>
      <span>${escapeHtml(field.label)}</span></label>`;
  }

  if(field.type==='select'){
    const options=(APP.catalogs[field.optionsKey]||[])
      .map(opt=>`<option value="${opt.id}" ${String(opt.id)===String(data[field.name]||'')?'selected':''}>${escapeHtml(opt[field.textKey]||'')}</option>`)
      .join('');

    return `<div class="field">
      <label>${escapeHtml(field.label)}</label>
      <select name="${field.name}" ${field.required?'required':''}>
        <option value="">Seleccione...</option>
        ${options}
      </select>
    </div>`;
  }

  if(field.type==='file'){
    return `<div class="field field-full">
      <label>${escapeHtml(field.label)}</label>
      <input type="file" name="${field.name}" accept="${field.accept||''}">
      ${data.strImagen?`<div style="margin-top:12px"><img src="${escapeAttr(data.strImagen)}" alt="Foto" class="detail-image"></div>`:''}
    </div>`;
  }

  if(field.name==='strNumeroCelular'){
    return `<div class="field">
      <label>${escapeHtml(field.label)}</label>
      <input
        type="text"
        name="${field.name}"
        maxlength="10"
        inputmode="numeric"
        pattern="[0-9]{10}"
        value="${escapeAttr(data[field.name]??'')}"
        ${field.required?'required':''}
        oninput="this.value=this.value.replace(/\D/g,'').slice(0,10)"
      >
    </div>`;
  }

  return `<div class="field">
    <label>${escapeHtml(field.label)}</label>
    <input type="${field.type}" name="${field.name}" maxlength="${field.maxLength||''}" value="${escapeAttr(data[field.name]??'')}" ${field.required?'required':''}>
  </div>`;
}


async function saveRecord(e){
  e.preventDefault();
  const schema=schemas[APP.state.moduleKey];
  const id=e.target.querySelector('[name="id"]').value;
  const hasFile=schema.form.some(f=>f.type==='file');
  const method=id?'PUT':'POST';
  let options={method};

  if(hasFile){
    const fd=new FormData(e.target); fd.delete('id');
    schema.form.forEach(field=>{ if(field.type==='checkbox') fd.set(field.name,fd.get(field.name)?'true':'false'); });
    options.body=fd;
  } else {
    const payload={};
    schema.form.forEach(field=>{
      const el=e.target.querySelector(`[name="${field.name}"]`);
      if(!el) return;
      payload[field.name]=field.type==='checkbox'?el.checked:el.value;
    });
    if(APP.state.moduleKey==='permisos_perfil'){
      payload.bitAgregar=false; payload.bitEditar=false;
      payload.bitConsulta=false; payload.bitEliminar=false; payload.bitDetalle=false;
    }
    options.headers={'Content-Type':'application/json'};
    options.body=JSON.stringify(payload);
  }

  if(APP.state.moduleKey==='usuario'){
    const phoneInput=e.target.querySelector('[name="strNumeroCelular"]');
    const phone=(phoneInput?.value || '').trim();
    if(!/^\d{10}$/.test(phone)){
      alert('El número de teléfono debe tener exactamente 10 dígitos.');
      if(phoneInput) phoneInput.focus();
      return;
    }
  }

  const res=await fetch(id?`${schema.endpoint}/${id}`:schema.endpoint,options);
  const json=await res.json();
  if(!res.ok||!json.ok){ alert(json.message||'No se pudo guardar'); return; }
  if(APP.state.moduleKey==='perfil'){
    const catRes=await fetch('/api/catalogos/base');
    APP.catalogs=await catRes.json();
  }
  showStatusModal('¡Guardado!',id?'El registro se actualizó correctamente.':'El registro se creó correctamente.');
  loadList(id?APP.state.page:1);
}


async function savePermissionRow(button,rowId,idPerfil,idModulo){
  const tr=button.closest('tr');
  const payload={
    idPerfil,idModulo,
    bitAgregar:tr.querySelector('[data-field="bitAgregar"]').checked,
    bitEditar:tr.querySelector('[data-field="bitEditar"]').checked,
    bitConsulta:tr.querySelector('[data-field="bitConsulta"]').checked,
    bitEliminar:tr.querySelector('[data-field="bitEliminar"]').checked,
    bitDetalle:tr.querySelector('[data-field="bitDetalle"]').checked
  };
  const res=await fetch(`/api/permisos-perfil/${rowId||0}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
  const json=await res.json();
  if(!res.ok||!json.ok){ alert(json.message||'No se pudo guardar'); return; }
  showStatusModal('¡Guardado!','Los permisos se actualizaron correctamente.');
  await loadPermissionRows(APP.state.page||1);
  renderPermissionsTable(schemas.permisos_perfil,APP.state.permissionRows||[],APP.state.permissionTotalPages||1);
}

function viewPermissionRecord(encodedRow){
  const data=JSON.parse(decodeURIComponent(encodedRow));
  const html=`
    <div class="detail-grid">
      <div class="field"><label>Perfil</label><div class="detail-box">${escapeHtml(data.strNombrePerfil||'')}</div></div>
      <div class="field"><label>Módulo</label><div class="detail-box">${escapeHtml(data.strNombreModulo||'')}</div></div>
      <div class="field"><label>Agregar</label><div class="detail-box">${boolToText(!!data.bitAgregar)}</div></div>
      <div class="field"><label>Editar</label><div class="detail-box">${boolToText(!!data.bitEditar)}</div></div>
      <div class="field"><label>Consulta</label><div class="detail-box">${boolToText(!!data.bitConsulta)}</div></div>
      <div class="field"><label>Eliminar</label><div class="detail-box">${boolToText(!!data.bitEliminar)}</div></div>
      <div class="field"><label>Detalle</label><div class="detail-box">${boolToText(!!data.bitDetalle)}</div></div>
    </div>
    <div class="modal-actions" style="justify-content:flex-end;margin-top:22px">
      <button type="button" class="btn btn-secondary" onclick="closeDetailModal()">Cerrar</button>
    </div>`;
  openDetailModal('Detalle de permiso',html);
}

function confirmPermissionDelete(id){
  openConfirmModal('Confirmar eliminación','¿Deseas eliminar este registro de permisos del perfil seleccionado?',async()=>{
    const res=await fetch(`/api/permisos-perfil/${id}`,{method:'DELETE'});
    const json=await res.json();
    if(!res.ok||!json.ok){ alert(json.message||'No se pudo eliminar'); return; }
    closeConfirmModal();
    showStatusModal('Eliminado','El permiso se eliminó correctamente.');
    await loadPermissionRows(APP.state.page||1);
    renderPermissionsTable(schemas.permisos_perfil,APP.state.permissionRows||[],APP.state.permissionTotalPages||1);
  });
}

function normalizeDetailValue(key,value){
  if(key==='bitAdministrador'||key.startsWith('bit')) return boolToText(!!value);
  if(key==='strImagen') return value?`<img src="${escapeAttr(value)}" alt="Imagen" class="detail-image">`:'Sin foto';
  if(key==='idPerfil'){ const item=(APP.catalogs.perfiles||[]).find(x=>String(x.id)===String(value)); return escapeHtml(item?.strNombrePerfil||value||''); }
  if(key==='idEstadoUsuario'){ const item=(APP.catalogs.estados||[]).find(x=>String(x.id)===String(value)); return escapeHtml(item?.strNombreEstado||value||''); }
  return escapeHtml(value??'');
}

async function viewRecord(id){
  const schema=schemas[APP.state.moduleKey];
  const data=await getRecord(id);
  const hiddenKeys=APP.state.moduleKey==='permisos_perfil'?['idPerfil','idModulo']:[];
  const keys=Object.keys(data).filter(k=>k!=='id'&&!hiddenKeys.includes(k));
  const html=`
    <div class="detail-grid">
      ${keys.map(key=>`
        <div class="field ${key==='strImagen'?'field-full':''}">
          <label>${escapeHtml(schema.detailLabels?.[key]||key)}</label>
          <div class="detail-box">${normalizeDetailValue(key,data[key])}</div>
        </div>`).join('')}
    </div>
    <div class="modal-actions" style="justify-content:flex-end;margin-top:22px">
      <button type="button" class="btn btn-secondary" onclick="closeDetailModal()">Cerrar</button>
    </div>`;
  openDetailModal(`Detalle de ${schema.singleTitle}`,html);
}

function confirmDelete(id){
  openConfirmModal('Confirmar eliminación','¿Estás seguro de que deseas eliminar este registro? Esta acción no se puede deshacer.',async()=>{
    const schema=schemas[APP.state.moduleKey];
    const res=await fetch(`${schema.endpoint}/${id}`,{method:'DELETE'});
    const json=await res.json();
    if(!res.ok||!json.ok){ alert(json.message||'No se pudo eliminar'); return; }
    closeConfirmModal();
    showStatusModal('Eliminado','El registro se eliminó correctamente.');
    loadList(APP.state.page);
  });
}


function openDetailModal(title,html){
  document.getElementById('detailModalTitle').textContent=title;
  document.getElementById('detailModalBody').innerHTML=html;
  document.getElementById('detailModalOverlay').style.display='flex';
}
function closeDetailModal(){
  document.getElementById('detailModalOverlay').style.display='none';
  document.getElementById('detailModalBody').innerHTML='';
}
function openConfirmModal(title,message,onAccept){
  document.getElementById('confirmModalTitle').textContent=title;
  document.getElementById('confirmModalMessage').textContent=message;
  APP.confirmAction=onAccept;
  document.getElementById('confirmModalOverlay').style.display='flex';
}
function closeConfirmModal(){
  document.getElementById('confirmModalOverlay').style.display='none';
  APP.confirmAction=null;
}
document.getElementById('confirmModalAccept').addEventListener('click',()=>{if(APP.confirmAction)APP.confirmAction();});
function showStatusModal(title,message){
  document.getElementById('statusModalTitle').textContent=title;
  document.getElementById('statusModalMessage').textContent=message;
  document.getElementById('statusModalOverlay').style.display='flex';
  clearTimeout(APP.statusTimer);
  APP.statusTimer=setTimeout(closeStatusModal,2000);
}
function closeStatusModal(){document.getElementById('statusModalOverlay').style.display='none';}
document.querySelectorAll('.modal-overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.style.display='none';}));

boot();
</script>
</body>
</html>
