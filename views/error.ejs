<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error</title>
  <style>
    body{margin:0;font-family:Segoe UI,Tahoma,Geneva,Verdana,sans-serif;background:linear-gradient(135deg,#0f172a,#1e1b4b,#312e81);min-height:100vh;display:grid;place-items:center;padding:24px}
    .box{max-width:520px;width:100%;background:#fff;border-radius:24px;padding:36px;box-shadow:0 24px 60px rgba(0,0,0,.35);text-align:center}
    h1{font-size:64px;margin:0;color:#7c3aed} p{color:#475569;font-size:18px} a{display:inline-block;margin-top:18px;background:linear-gradient(135deg,#4881ec,#41a9e6);color:#fff;text-decoration:none;padding:12px 18px;border-radius:12px;font-weight:700}
  </style>
</head>
<body>
  <div class="box">
    <h1><%= code %></h1>
    <p><%= message %></p>
    <a href="/">Volver al login</a>
  </div>
</body>
</html>
