<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= persona ? 'Editar Persona' : 'Nueva Persona' %>
    </title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
            min-height: 100vh;
        }

        /* HEADER */
        .header {
            background: rgba(255, 255, 255, .95);
            padding: 24px 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, .3);
            margin-bottom: 20px;
        }

        .header-content {
            max-width: 900px;
            margin: 0 auto;
        }

        h1 {
            background: linear-gradient(135deg, #ec4899 0%, #a855f7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 26px;
            font-weight: 700;
        }

        /* CONTAINER */
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px 40px;
        }

        /* BREADCRUMBS */
        .breadcrumbs {
            background: white;
            padding: 14px 22px;
            border-radius: 12px;
            margin-bottom: 25px;
            display: flex;
            gap: 10px;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, .15);
        }

        .breadcrumbs a {
            text-decoration: none;
            color: #64748b;
            font-weight: 500;
        }

        .breadcrumbs .active {
            background: linear-gradient(135deg, #ec4899 0%, #a855f7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        .breadcrumbs span {
            color: #94a3b8;
        }

        /* CARD */
        .form-card {
            background: white;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, .3);
        }

        label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
            color: #475569;
        }

        input {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #cbd5e1;
            margin-bottom: 15px;
        }

        input:focus {
            outline: none;
            border-color: #a855f7;
        }

        .btn {
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: linear-gradient(135deg, #ec4899 0%, #a855f7 100%);
            color: white;
        }

        .btn-secondary {
            background: #64748b;
            color: white;
        }
    </style>
</head>

<body>

    <div class="header">
        <div class="header-content">
            <h1>
                <%= persona ? 'Editar Persona' : 'Nueva Persona' %>
            </h1>
        </div>
    </div>

    <div class="container">

        <div class="breadcrumbs">
            <a href="/dashboard">Inicio</a>
            <span>›</span>
            <a href="/crud">CRUD Personas</a>
            <span>›</span>
            <a class="active">
                <%= persona ? 'Editar' : 'Nuevo' %>
            </a>
        </div>

        <div class="form-card">
            <form method="POST">

                <label>Nombre Completo</label>
                <input type="text" name="nombre_completo" value="<%= persona?.nombre_completo || '' %>" maxlength="30"
                    pattern="[A-Za-zÁÉÍÓÚáéíóúñÑ\s]+" required>

                <label>País</label>
                <input type="text" name="pais" value="<%= persona?.pais || '' %>" maxlength="10" 
                pattern="[A-Za-zÁÉÍÓÚáéíóúñÑ\s]+" required>

                <label>Estado</label>
                <input type="text" name="estado" value="<%= persona?.estado || '' %>" maxlength="10"
                pattern="[A-Za-zÁÉÍÓÚáéíóúñÑ\s]+" required>

                <label>Dirección</label>
                <input type="text" name="direccion" value="<%= persona?.direccion || '' %>" maxlength="30" required>

                <label>Código Postal</label>
                <input type="text" name="codigo_postal" value="<%= persona?.codigo_postal || '' %>" maxlength="5"
                    pattern="[0-9]{5}" required>

                <button class="btn btn-primary">Guardar</button>
                <a href="/crud" class="btn btn-secondary">Cancelar</a>

            </form>
        </div>

    </div>
</body>

</html>