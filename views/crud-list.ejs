<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CRUD Personas</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;}

body{
font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#312e81 100%);
min-height:100vh;
overflow-x:hidden;
}

/* HEADER */
.header{
background:rgba(255,255,255,.95);
padding:24px 30px;
box-shadow:0 4px 20px rgba(0,0,0,.3);
margin-bottom:20px;
}

.header-content{
max-width:1400px;
margin:0 auto;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:15px;
}

h1{
background:linear-gradient(135deg,#ec4899 0%,#a855f7 100%);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
font-size:28px;
font-weight:700;
}

.btn{
padding:10px 20px;
border-radius:10px;
text-decoration:none;
font-weight:600;
font-size:14px;
border:none;
cursor:pointer;
display:inline-flex;
align-items:center;
gap:8px;
}

.btn-primary{
background:linear-gradient(135deg,#ec4899 0%,#a855f7 100%);
color:white;
}

.btn-secondary{
background:#64748b;
color:white;
}

/* CONTAINER */
.container{
max-width:1400px;
margin:0 auto;
padding:0 20px 40px;
}

/* BREADCRUMBS */
.breadcrumbs{
background:white;
padding:14px 22px;
border-radius:12px;
margin-bottom:25px;
display:flex;
gap:10px;
align-items:center;
box-shadow:0 4px 15px rgba(0,0,0,.15);
}

.breadcrumbs a{
text-decoration:none;
color:#64748b;
font-weight:500;
}

.breadcrumbs a:hover{
color:#a855f7;
}

.breadcrumbs .active{
background:linear-gradient(135deg,#ec4899 0%,#a855f7 100%);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
font-weight:700;
}

.breadcrumbs span{
color:#94a3b8;
}

/* SEARCH */
.search-box{
padding:20px;
display:flex;
gap:10px;
}

.search-box input{
padding:10px;
border-radius:8px;
border:1px solid #cbd5e1;
width:250px;
}

/* TABLE */
.table-container{
background:rgba(255,255,255,.95);
border-radius:16px;
box-shadow:0 8px 30px rgba(0,0,0,.3);
overflow:hidden;
}

table{
width:100%;
border-collapse:collapse;
}

thead{
background:linear-gradient(135deg,#ec4899 0%,#a855f7 100%);
}

thead th{
color:white;
padding:16px 12px;
text-align:left;
}

tbody td{
padding:14px 12px;
color:#475569;
border-bottom:1px solid #f1f5f9;
}

tbody tr:hover{
background:rgba(236,72,153,.05);
}

.action-buttons{
display:flex;
gap:8px;
}

.btn-sm{
padding:6px 12px;
font-size:13px;
border-radius:8px;
}

.btn-edit{
background:#f59e0b;
color:white;
}

.btn-delete{
background:#ef4444;
color:white;
}

.empty-state{
text-align:center;
padding:50px;
color:#64748b;
}

/* PAGINATION */
.pagination{
padding:20px;
display:flex;
justify-content:center;
gap:10px;
}
</style>
</head>

<body>

<div class="header">
<div class="header-content">
<h1>Gestión de Personas</h1>
<div>
<a href="/crud/nuevo" class="btn btn-primary">Agregar Persona</a>
<a href="/dashboard" class="btn btn-secondary">Volver</a>
</div>
</div>
</div>

<div class="container">

<div class="breadcrumbs">
<a href="/dashboard">Inicio</a>
<span>›</span>
<a href="/crud" class="active">CRUD Personas</a>
</div>

<div class="search-box">
<input type="text" id="buscar" placeholder="Buscar por nombre..." value="<%= search || '' %>">
<button onclick="buscarPersona()" class="btn btn-primary">Buscar</button>
</div>

<div class="table-container">

<table>

<thead>
<tr>
<th>Nombre</th>
<th>País</th>
<th>Estado</th>
<th>Dirección</th>
<th>CP</th>
<th>Acciones</th>
</tr>
</thead>

<tbody>

<% if (personas && personas.length > 0) { %>

<% personas.forEach(p => { %>

<tr>

<td><%= p.nombre_completo %></td>
<td><%= p.pais %></td>
<td><%= p.estado %></td>
<td><%= p.direccion %></td>
<td><%= p.codigo_postal %></td>

<td>
<div class="action-buttons">

<a href="/crud/editar/<%= p.id %>" class="btn btn-edit btn-sm">
Editar
</a>

<a href="/crud/eliminar/<%= p.id %>"
class="btn btn-delete btn-sm"
onclick="return confirm('¿Seguro que deseas eliminar este registro?')">
Eliminar
</a>

</div>
</td>

</tr>

<% }) %>

<% } else { %>

<tr>
<td colspan="6">
<div class="empty-state">
<p>No hay personas registradas</p>
</div>
</td>
</tr>

<% } %>

</tbody>
</table>

</div>

<div class="pagination">

<% if(page > 1){ %>

<a class="btn btn-secondary"
href="/crud?page=<%= page-1 %>&search=<%= search %>">
Anterior
</a>

<% } %>

<% if(page < totalPages){ %>

<a class="btn btn-primary"
href="/crud?page=<%= page+1 %>&search=<%= search %>">
Siguiente
</a>

<% } %>

</div>

</div>

<script>

function buscarPersona(){

const texto = document.getElementById("buscar").value;

window.location = `/crud?search=${texto}`;

}

</script>

</body>
</html>