<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <style>
    *{box-sizing:border-box} body{margin:0;font-family:Segoe UI,Tahoma,Geneva,Verdana,sans-serif;background:linear-gradient(135deg,#048815,#1e1b4b,#3c2a6e);min-height:100vh;display:grid;place-items:center;padding:20px}
    .card{width:100%;max-width:420px;background:rgba(255,255,255,.96);border-radius:22px;padding:34px;box-shadow:0 24px 60px rgba(0,0,0,.35)}
    h1{margin:0 0 8px;background:linear-gradient(135deg,#4881ec,#41a9e6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center}.sub{margin:0 0 22px;color:#64748b;text-align:center}
    .group{margin-bottom:16px} label{display:block;margin-bottom:8px;font-weight:600;color:#334155} input{width:100%;padding:14px 15px;border:2px solid #e2e8f0;border-radius:12px}
    input:focus{outline:none;border-color:#a855f7;box-shadow:0 0 0 4px rgba(168,85,247,.12)} .error{display:<%= error ? 'block' : 'none' %>;background:#fee2e2;color:#b91c1c;padding:12px 14px;border-radius:12px;margin-bottom:18px}
    button{width:100%;border:none;border-radius:12px;padding:14px 16px;background:linear-gradient(135deg,#4881ec,#41a9e6);color:#fff;font-size:16px;font-weight:700;cursor:pointer} .note{margin-top:16px;color:#64748b;text-align:center;font-size:13px}
    .captcha-wrap{display:flex;justify-content:center;margin:20px 0}
  </style>
</head>
<body>
  <div class="card">
    <h1>Sistema Empresarial</h1>
    <p class="sub">Proyecto coorporativo.</p>
    <div class="error"><%= error %></div>
    <form method="POST" action="/login">
      <div class="group">
        <label for="usuario">Usuario o correo</label>
        <input id="usuario" name="usuario" maxlength="80" required>
      </div>
      <div class="group">
        <label for="password">Contraseña</label>
        <input id="password" name="password" type="password" maxlength="120" required>
      </div>
      <div class="captcha-wrap">
        <div class="g-recaptcha" data-sitekey="<%= siteKey %>"></div>
      </div>
      <button type="submit">Iniciar sesión</button>
    </form>
    <div class="note">Si no tienes permisos para una ruta, serás redirigido al login.</div>
  </div>
</body>
</html>
